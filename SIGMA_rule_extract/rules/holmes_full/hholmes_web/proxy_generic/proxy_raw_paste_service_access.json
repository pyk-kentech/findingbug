{
  "name": "Raw Paste Service Access",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Event",
      "attributes": {
        "c-uri|contains": [
          ".paste.ee/r/",
          ".pastebin.com/raw/",
          ".hastebin.com/raw/",
          ".ghostbin.co/paste/*/raw/",
          "pastetext.net/",
          "pastebin.pl/",
          "paste.ee/"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}