{
  "name": "Suspicious External WebDAV Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "c-useragent|startswith": "Microsoft-WebDAV-MiniRedir/",
        "cs-method": "GET"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "c-uri|endswith": [
          ".7z",
          ".bat",
          ".dat",
          ".cmd",
          ".exe",
          ".js",
          ".lnk",
          ".ps1",
          ".rar",
          ".url",
          ".vbe",
          ".vbs",
          ".zip"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}