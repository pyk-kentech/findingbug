{
  "name": "AWS Identity Center Identity Provider Change",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventSource|endswith": [
          "sso-directory.amazonaws.com",
          "sso.amazonaws.com"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "eventName": [
          "AssociateDirectory",
          "DisableExternalIdPConfigurationForDirectory",
          "DisassociateDirectory",
          "EnableExternalIdPConfigurationForDirectory"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}