{
  "name": "AWS S3 Data Management Tampering",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventSource": "s3.amazonaws.com"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "eventName": [
          "PutBucketLogging",
          "PutBucketWebsite",
          "PutEncryptionConfiguration",
          "PutLifecycleConfiguration",
          "PutReplicationConfiguration",
          "ReplicateObject",
          "RestoreObject"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}