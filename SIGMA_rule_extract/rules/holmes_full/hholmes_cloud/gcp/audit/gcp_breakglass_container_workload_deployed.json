{
  "name": "GCP Break-glass Container Workload Deployed",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "data.protoPayload.methodName": "io.k8s.core.v1.pods.create"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "data.protoPayload.resource.type": "k8s_cluster",
        "data.protoPayload.logName": [
          "cloudaudit.googleapis.com/activity",
          "cloudaudit.googleapis.com%2Factivity"
        ],
        "keywords": [
          "image-policy.k8s.io/break-glass"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}