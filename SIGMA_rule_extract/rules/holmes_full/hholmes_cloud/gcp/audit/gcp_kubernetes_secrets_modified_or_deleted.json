{
  "name": "Google Cloud Kubernetes Secrets Modified or Deleted",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "gcp.audit.method_name": [
          "io.k8s.core.v*.secrets.create",
          "io.k8s.core.v*.secrets.update",
          "io.k8s.core.v*.secrets.patch",
          "io.k8s.core.v*.secrets.delete"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}