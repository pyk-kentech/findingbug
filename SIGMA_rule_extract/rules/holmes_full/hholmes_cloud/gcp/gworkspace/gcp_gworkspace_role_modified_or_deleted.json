{
  "name": "Google Workspace Role Modified or Deleted",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventService": "admin.googleapis.com",
        "eventName": [
          "DELETE_ROLE",
          "RENAME_ROLE",
          "UPDATE_ROLE"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}