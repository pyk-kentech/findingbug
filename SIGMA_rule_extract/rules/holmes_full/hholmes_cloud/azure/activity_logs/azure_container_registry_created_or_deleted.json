{
  "name": "Azure Container Registry Created or Deleted",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "operationName": "MICROSOFT.CONTAINERREGISTRY/REGISTRIES/WRITE|MICROSOFT.CONTAINERREGISTRY/REGISTRIES/DELETE"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}