{
  "name": "Users Authenticating To Other Azure AD Tenants",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "Status": "Success",
        "HomeTenantId": "HomeTenantID"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "ResourceTenantId|contains": "HomeTenantID"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}