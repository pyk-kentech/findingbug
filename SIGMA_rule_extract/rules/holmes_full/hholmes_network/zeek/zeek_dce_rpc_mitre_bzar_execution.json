{
  "name": "MITRE BZAR Indicators for Execution",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "endpoint": [
          "JobAdd",
          "ITaskSchedulerService",
          "ITaskSchedulerService",
          "ITaskSchedulerService",
          "IWbemServices",
          "IWbemServices",
          "svcctl",
          "svcctl",
          "svcctl",
          "svcctl"
        ],
        "operation": [
          "atsvc",
          "SchRpcEnableTask",
          "SchRpcRegisterTask",
          "SchRpcRun",
          "ExecMethod",
          "ExecMethodAsync",
          "CreateServiceA",
          "CreateServiceW",
          "StartServiceA",
          "StartServiceW"
        ]
      }
    },
    "object": {
      "type": "Event",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}