{
  "name": "MITRE BZAR Indicators for Persistence",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "endpoint": [
          "spoolss",
          "IRemoteWinspool",
          "ISecLogon"
        ],
        "operation": [
          "RpcAddMonitor",
          "RpcAddPrintProcessor",
          "RpcAsyncAddMonitor",
          "RpcAsyncAddPrintProcessor",
          "SeclCreateProcessWithLogonW",
          "SeclCreateProcessWithLogonExW"
        ]
      }
    },
    "object": {
      "type": "Event",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}