{
  "name": "Executable from Webdav",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "c-useragent": "*WebDAV*",
        "c-uri": "*webdav*"
      }
    },
    "object": {
      "type": "Event",
      "attributes": {
        "resp_mime_types": "*dosexec*",
        "c-uri": "*.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}