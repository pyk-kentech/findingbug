{
  "name": "Suspicious Use of /dev/tcp",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "command_line": [
          "cat </dev/tcp/*",
          "exec 3<>/dev/tcp/*",
          "echo >/dev/tcp/*",
          "bash -i >& /dev/tcp/*",
          "sh -i >& /dev/udp/*",
          "0<&196;exec 196<>/dev/tcp/*",
          "exec 5<>/dev/tcp/*",
          "(sh)0>/dev/tcp/*",
          "bash -c 'bash -i >& /dev/tcp/*'",
          "echo -e '#!/bin/bash\\nbash -i >& /dev/tcp/*'"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}