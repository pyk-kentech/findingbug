{
  "name": "Password Policy Discovery - Linux",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Event",
      "attributes": {
        "type": "PATH"
      }
    },
    "object": {
      "type": "Event",
      "attributes": {
        "name": [
          "/etc/login.defs",
          "/etc/pam.d/auth",
          "/etc/pam.d/common-account",
          "/etc/pam.d/common-auth",
          "/etc/pam.d/common-password",
          "/etc/pam.d/system-auth",
          "/etc/security/pwquality.conf"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}