{
  "name": "History File Deletion",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/rm",
          "/unlink",
          "/shred"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "/.bash_history",
          "/.zsh_history"
        ],
        "CommandLine|endswith": [
          "_history",
          ".history",
          "zhistory"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}