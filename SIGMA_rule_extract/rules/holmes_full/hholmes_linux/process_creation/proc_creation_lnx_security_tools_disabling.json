            "iptables",
            "stop"
          ],
          [
            "ip6tables",
            "stop"
          ],
          [
            "iptables",
            "stop"
          ],
          [
            "ip6tables",
            "stop"
          ],
          [
            "firewalld",
            "stop"
          ],
          [
            "firewalld",
            "disable"
          ],
          [
            "cbdaemon",
            "stop"
          ],
          [
            "cbdaemon",
            "off"
          ],
          [
            "cbdaemon",
            "stop"
          ],
          [
            "cbdaemon",
            "disable"
          ],
          [
            "0"
          ]
        ],
        "CommandLine|contains": [
          "falcon-sensor"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
