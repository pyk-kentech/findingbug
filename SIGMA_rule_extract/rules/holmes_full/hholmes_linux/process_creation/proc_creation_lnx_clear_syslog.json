{
  "name": "Syslog Clearing or Removal Via System Utilities",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "/var/log/syslog",
          " > /var/log/syslog",
          " >/var/log/syslog",
          " >| /var/log/syslog",
          ": > /var/log/syslog",
          ":> /var/log/syslog",
          ":>/var/log/syslog",
          ">|/var/log/syslog"
        ],
        "Image|endswith": [
          "/rm",
          "/unlink",
          "/mv",
          "/truncate",
          "/ln",
          "/cp",
          "/shred"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "/var/log/syslog"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}