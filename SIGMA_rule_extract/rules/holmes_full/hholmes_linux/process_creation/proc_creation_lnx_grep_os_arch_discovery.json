{
  "name": "OS Architecture Discovery Via Grep",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "/grep"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|endswith": [
          "aarch64",
          "arm",
          "i386",
          "i686",
          "mips",
          "x86_64"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}