{
  "name": "Suspicious Java Children Processes",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "/java"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "/bin/sh",
          "bash",
          "dash",
          "ksh",
          "zsh",
          "csh",
          "fish",
          "curl",
          "wget",
          "python"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}