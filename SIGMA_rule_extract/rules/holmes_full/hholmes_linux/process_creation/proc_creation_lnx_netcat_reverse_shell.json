{
  "name": "Potential Netcat Reverse Shell Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/nc",
          "/ncat"
        ],
        "CommandLine|contains": [
          " -c ",
          " -e "
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          " ash",
          " bash",
          " bsh",
          " csh",
          " ksh",
          " pdksh",
          " sh",
          " tcsh",
          "/bin/ash",
          "/bin/bash",
          "/bin/bsh",
          "/bin/csh",
          "/bin/ksh",
          "/bin/pdksh",
          "/bin/sh",
          "/bin/tcsh",
          "/bin/zsh",
          "$IFSash",
          "$IFSbash",
          "$IFSbsh",
          "$IFScsh",
          "$IFSksh",
          "$IFSpdksh",
          "$IFSsh",
          "$IFStcsh",
          "$IFSzsh"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}