{
  "name": "Suspicious Download and Execute Pattern via Curl/Wget",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "command_line|contains": [
          "/curl",
          "/wget"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path|contains": [
          "/tmp/",
          "/dev/shm/"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}