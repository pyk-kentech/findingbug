{
  "name": "Container Residence Discovery Via Proc Virtual FS",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "awk",
          "/cat",
          "grep",
          "/head",
          "/less",
          "/more",
          "/nl",
          "/tail"
        ],
        "CommandLine|contains": [
          "/proc/2/",
          "/proc/"
        ],
        "CommandLine|endswith": [
          "/cgroup",
          "/sched"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}