{
  "name": "MSSQL Disable Audit Settings",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name|contains": "MSSQL"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "EventID": 33205,
        "Data|contains": [
          "statement:ALTER SERVER AUDIT",
          "statement:DROP SERVER AUDIT"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}