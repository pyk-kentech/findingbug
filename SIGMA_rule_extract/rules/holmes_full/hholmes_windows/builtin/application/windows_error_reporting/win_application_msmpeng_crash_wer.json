{
  "name": "Microsoft Malware Protection Engine Crash - WER",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Windows Error Reporting"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "EventID": 1001,
        "Data|contains|all": [
          "MsMpEng.exe",
          "mpengine.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}