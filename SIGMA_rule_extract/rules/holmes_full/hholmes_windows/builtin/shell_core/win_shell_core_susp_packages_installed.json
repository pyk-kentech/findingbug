{
  "name": "Suspicious Application Installed",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "28115",
        "Name|contains": [
          "Zenmap",
          "AnyDesk",
          "wireshark",
          "openvpn"
        ],
        "AppID|contains": [
          "zenmap.exe",
          "prokzult ad",
          "# AnyDesk"
        ],
        "wireshark": null,
        "openvpn": null
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}