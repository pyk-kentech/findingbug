{
  "name": "Remote PowerShell Sessions Network Connections (WinRM)",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "5156",
        "LayerRTID": "44"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestPort": [
          "5985",
          "5986"
        ]
      }
    },
    "entity_bindings": {
