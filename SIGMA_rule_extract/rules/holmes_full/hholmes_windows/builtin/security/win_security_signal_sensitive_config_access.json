{
  "name": "File Access Of Signal Desktop Sensitive Data",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "ProcessName|endswith": [
          "\\signal-portable.exe",
          "\\signal.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "ObjectName|contains": "\\AppData\\Roaming\\Signal\\",
        "ObjectName|endswith": [
          "\\config.json",
          "\\db.sqlite"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}