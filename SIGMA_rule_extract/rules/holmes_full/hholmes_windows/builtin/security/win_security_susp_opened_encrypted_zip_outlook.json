{
  "name": "Password Protected ZIP File Opened (Email Attachment)",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "5379"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetName|contains|all": [
          "Microsoft_Windows_Shell_ZipFolder:filename",
          "\\Temporary Internet Files\\Content.Outlook"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}