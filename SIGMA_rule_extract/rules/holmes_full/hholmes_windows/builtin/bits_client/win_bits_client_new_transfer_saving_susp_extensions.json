{
  "name": "BITS Transfer Job Downloading File Potential Suspicious Extension",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "16403"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "LocalName|endswith": [
          ".bat",
          ".dll",
          ".exe",
          ".hta",
          ".ps1",
          ".psd1",
          ".sh",
          ".vbe",
          ".vbs"
        ],
        "RemoteName|contains": ".com",
        "LocalName|contains": "\\AppData\\"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}