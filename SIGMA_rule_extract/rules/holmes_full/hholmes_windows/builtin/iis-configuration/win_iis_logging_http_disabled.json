{
  "name": "HTTP Logging Disabled On IIS Server",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "29"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Configuration": "/system.webServer/httpLogging/@dontLog",
        "NewValue": "true"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}