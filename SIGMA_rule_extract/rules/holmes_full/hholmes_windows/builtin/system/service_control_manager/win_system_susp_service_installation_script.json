{
  "name": "Suspicious Service Installation Script",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Service Control Manager",
        "EventID": 7045,
        "ImagePath|contains|windash": [
          " -c ",
          " -r ",
          " -k "
        ],
        "ImagePath|contains": [
          "cscript",
          "mshta",
          "powershell",
          "pwsh",
          "regsvr32",
          "rundll32",
          "wscript"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}