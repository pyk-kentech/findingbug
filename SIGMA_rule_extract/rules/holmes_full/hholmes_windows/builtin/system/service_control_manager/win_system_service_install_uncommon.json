{
  "name": "Uncommon Service Installation Image Path",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Service Control Manager"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImagePath|contains": [
          "\\\\.\\",
          "\\Users\\Public\\",
          "\\Windows\\Temp\\",
          " -e",
          " aQBlAHgA",
          " aWV4I",
          " IAB",
          " JAB",
          " PAA",
          " SQBFAFgA",
          " SUVYI"
        ],
        "ImagePath|startswith": [
          "C:\\WINDOWS\\TEMP\\thor10-remote\\thor64.exe",
          "C:\\ProgramData\\Microsoft\\Windows Defender\\Definition Updates\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}