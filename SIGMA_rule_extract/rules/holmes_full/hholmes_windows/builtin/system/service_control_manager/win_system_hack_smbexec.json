{
  "name": "smbexec.py Service Installation",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Service Control Manager"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ServiceName": "BTOBTO",
        "ImagePath|contains": [
          ".bat & del ",
          "__output 2^>^&1 >"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}