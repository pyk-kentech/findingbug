{
  "name": "Crash Dump Created By Operating System",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Microsoft-Windows-WER-SystemErrorReporting"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "EventID": 1001
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}