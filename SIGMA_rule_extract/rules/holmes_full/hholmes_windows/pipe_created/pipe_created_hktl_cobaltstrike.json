{
  "name": "CobaltStrike Named Pipe",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "PipeName|contains|all": [
          "\\MSSE-",
          "-server"
        ],
        "PipeName|startswith": [
          "\\postex_",
          "\\status_",
          "\\msagent_",
          "\\mojo_",
          "\\interprocess_",
          "\\samr_",
          "\\netlogon_",
          "\\srvsvc_",
          "\\lsarpc_",
          "\\wkssvc_"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}