{
  "name": "ADFS Database Named Pipe Connection By Uncommon Tool",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          ":\\Windows\\System32\\mmc.exe",
          ":\\Windows\\system32\\svchost.exe",
          ":\\Windows\\System32\\wsmprovhost.exe",
          ":\\Windows\\SysWOW64\\mmc.exe",
          ":\\Windows\\SysWOW64\\wsmprovhost.exe",
          ":\\Windows\\WID\\Binn\\sqlwriter.exe",
          "\\AzureADConnect.exe",
          "\\Microsoft.Identity.Health.Adfs.PshSurrogate.exe",
          "\\Microsoft.IdentityServer.ServiceHost.exe",
          "\\Microsoft.Tri.Sensor.exe",
          "\\sqlservr.exe",
          "\\tssdis.exe"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "PipeName": "\\MICROSOFT##WID\\tsql\\query"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}