{
  "name": "Terminal Server Client Connection History Cleared - Registry",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventType": "DeleteValue"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\Microsoft\\Terminal Server Client\\Default\\MRU"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}