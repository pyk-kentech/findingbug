{
  "name": "Delete Defender Scan ShellEx Context Menu Registry Key",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\",
          "C:\\Program Files\\Windows Defender\\",
          "C:\\Program Files (x86)\\Windows Defender\\"
        ],
        "Image|endswith": "\\MsMpEng.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "shellex\\ContextMenuHandlers\\EPP"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}