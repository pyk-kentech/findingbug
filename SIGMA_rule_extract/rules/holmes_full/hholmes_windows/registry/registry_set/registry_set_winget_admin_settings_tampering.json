{
  "name": "Winget Admin Settings Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\winget.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|startswith": "\\REGISTRY\\A\\",
        "TargetObject|endswith": "\\LocalState\\admin_settings"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}