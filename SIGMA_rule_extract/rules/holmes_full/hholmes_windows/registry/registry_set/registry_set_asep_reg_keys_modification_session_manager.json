{
  "name": "Session Manager Autorun Keys Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": "\\\\System\\\\CurrentControlSet\\\\Control\\\\Session Manager"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\\\SetupExecute",
          "\\\\S0InitialCommand",
          "\\\\KnownDlls",
          "\\\\Execute",
          "\\\\BootExecute",
          "\\\\AppCertDlls"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}