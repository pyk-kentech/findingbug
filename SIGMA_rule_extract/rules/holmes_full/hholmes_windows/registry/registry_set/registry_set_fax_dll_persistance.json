{
  "name": "Change the Fax Dll",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains|all": [
          "\\Software\\Microsoft\\Fax\\Device Providers\\",
          "\\ImageName"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details": "%systemroot%\\system32\\fxst30.dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}