{
  "name": "Potential Persistence Via TypedPaths",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\explorer.exe",
          "\\SysWOW64\\explorer.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\Software\\Microsoft\\Windows\\CurrentVersion\\Explorer\\TypedPaths\\"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}