{
  "name": "COM Object Hijacking Via Modification Of Default System CLSID Default Value",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": "\\CLSID\\",
        "TargetObject|endswith": [
          "\\InprocServer32\\(Default)",
          "\\LocalServer32\\(Default)"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details|contains": [
          ":\\Perflogs\\",
          "\\AppData\\Local\\",
          "\\Desktop\\",
          "\\Downloads\\",
          "\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\",
          "\\System32\\spool\\drivers\\color\\",
          "\\Temporary Internet",
          "\\Users\\Public\\",
          "\\Windows\\Temp\\",
          "%appdata%",
          "%temp%",
          "%tmp%"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}