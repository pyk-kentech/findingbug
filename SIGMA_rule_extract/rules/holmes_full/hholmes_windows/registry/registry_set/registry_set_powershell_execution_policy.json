{
  "name": "Potential PowerShell Execution Policy Tampering",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          ":\\Windows\\System32\\",
          ":\\Windows\\SysWOW64\\"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|endswith": [
          "\\ShellIds\\Microsoft.PowerShell\\ExecutionPolicy",
          "\\Policies\\Microsoft\\Windows\\PowerShell\\ExecutionPolicy"
        ],
        "Details|contains": [
          "Bypass",
          "Unrestricted"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}