{
  "name": "Potential ClickFix Execution Pattern - Registry",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": "\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\RunMRU\\"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details|contains": [
          "http://",
          "https://",
          "account",
          "anti-bot",
          "botcheck",
          "captcha",
          "challenge",
          "confirmation",
          "fraud",
          "human",
          "identification",
          "identificator",
          "identity",
          "robot",
          "validation",
          "verification",
          "verify",
          "%comspec%",
          "bitsadmin",
          "certutil",
          "cmd",
          "cscript",
          "curl",
          "finger",
          "mshta",
          "powershell",
          "pwsh",
          "regsvr32",
          "rundll32",
          "schtasks",
          "wget",
          "wscript"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}