{
  "name": "VBScript Payload Stored in Registry",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": "Software\\Microsoft\\Windows\\CurrentVersion"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details|contains": [
          "vbscript:",
          "jscript:",
          "mshtml,",
          "RunHTMLApplication",
          "Execute(",
          "CreateObject",
          "window.close"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}