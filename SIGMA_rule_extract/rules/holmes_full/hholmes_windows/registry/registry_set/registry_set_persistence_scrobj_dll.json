{
  "name": "Potential Persistence Via Scrobj.dll COM Hijacking",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|endswith": "InprocServer32\\(Default)"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details": "C:\\WINDOWS\\system32\\scrobj.dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}