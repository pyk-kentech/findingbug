{
  "name": "Suspicious PowerShell In Registry Run Keys",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Details|contains": [
          "powershell",
          "pwsh ",
          "FromBase64String",
          ".DownloadFile(",
          ".DownloadString(",
          " -w hidden ",
          " -w 1 ",
          "-windowstyle hidden",
          "-window hidden",
          " -nop ",
          " -encodedcommand ",
          "-ExecutionPolicy Bypass",
          "Invoke-Expression",
          "IEX (",
          "Invoke-Command",
          "ICM -",
          "Invoke-WebRequest",
          "IWR ",
          "Invoke-RestMethod",
          "IRM ",
          " -noni ",
          " -noninteractive "
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
          "\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run",
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}