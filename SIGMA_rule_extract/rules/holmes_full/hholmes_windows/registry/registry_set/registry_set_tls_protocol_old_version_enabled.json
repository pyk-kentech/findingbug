{
  "name": "Old TLS1.0/TLS1.1 Protocol Version Enabled",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": [
          "\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.0\\",
          "\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.1\\"
        ],
        "TargetObject|endswith": "\\Enabled"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details": "DWORD (0x00000001)"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}