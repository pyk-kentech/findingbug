{
  "name": "Disabled Windows Defender Eventlog",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains": "\\\\Microsoft\\\\Windows\\\\CurrentVersion\\\\WINEVT\\\\Channels\\\\Microsoft-Windows-Windows Defender/Operational\\\\Enabled"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "Details": "DWORD (0x00000000)"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}