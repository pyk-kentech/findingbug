{
  "name": "Suspicious Camera and Microphone Access",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetObject|contains|all": [
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\CapabilityAccessManager\\ConsentStore\\",
          "\\NonPackaged"
        ],
        "TargetObject|contains": [
          "microphone",
          "webcam"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          ":#Windows#Temp#",
          ":#$Recycle.bin#",
          ":#Temp#",
          ":#Users#Public#",
          ":#Users#Default#",
          ":#Users#Desktop#"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}