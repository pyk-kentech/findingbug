{
  "name": "Registry Persistence Mechanisms in Recycle Bin",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventType": "RenameKey"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "NewName|contains": "\\CLSID\\{645FF040-5081-101B-9F08-00AA002F954E}\\shell\\open"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}