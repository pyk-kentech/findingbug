{
  "name": "Potential DLL Sideloading Of MsCorSvc.DLL",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\mscorsvc.dll"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Windows\\Microsoft.NET\\Framework\\",
          "C:\\Windows\\Microsoft.NET\\Framework64\\",
          "C:\\Windows\\Microsoft.NET\\FrameworkArm\\",
          "C:\\Windows\\Microsoft.NET\\FrameworkArm64\\",
          "C:\\Windows\\WinSxS\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}