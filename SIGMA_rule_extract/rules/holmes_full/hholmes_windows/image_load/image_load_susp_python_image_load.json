{
  "name": "Python Image Load By Non-Python Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Description": "Python Core"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          "python38.dll",
          "python.exe"
        ],
        "Image|startswith": [
          "C:\\Program Files\\",
          "C:\\Program Files (x86)\\",
          "C:\\ProgramData\\Anaconda3\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}