{
  "name": "Potential Chrome Frame Helper DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\chrome_frame_helper.dll"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Program Files\\Google\\Chrome\\Application\\",
          "C:\\Program Files (x86)\\Google\\Chrome\\Application\\"
        ],
        "ImageLoaded|contains": [
          "\\AppData\\local\\Google\\Chrome\\Application\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}