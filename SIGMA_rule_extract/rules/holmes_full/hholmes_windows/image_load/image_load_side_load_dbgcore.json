{
  "name": "Potential DLL Sideloading Of DBGCORE.DLL",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\dbgcore.dll"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Program Files (x86)\\",
          "C:\\Program Files\\",
          "C:\\Windows\\SoftwareDistribution\\",
          "C:\\Windows\\System32\\",
          "C:\\Windows\\SystemTemp\\",
          "C:\\Windows\\SysWOW64\\",
          "C:\\Windows\\WinSxS\\"
        ],
        "ImageLoaded|endswith": "\\assistant\\dbgcore.dll",
        "ImageLoaded|contains": "opera\\Opera Installer Temp\\opera_package"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}