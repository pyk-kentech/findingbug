{
  "name": "VMMap Unsigned Dbghelp.DLL Potential Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|contains": "C:\\Debuggers\\dbghelp.dll"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\vmmap.exe",
          "\\vmmap64.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}