{
  "name": "Potential Rcdll.DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\rcdll.dll"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Program Files (x86)\\Microsoft Visual Studio\\",
          "C:\\Program Files (x86)\\Windows Kits\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}