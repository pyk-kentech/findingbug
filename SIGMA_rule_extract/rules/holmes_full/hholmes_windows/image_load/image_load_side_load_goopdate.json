{
  "name": "Potential Goopdate.DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\goopdate.dll"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Program Files (x86)\\",
          "C:\\Program Files\\"
        ],
        "Image|contains|all": [
          "\\AppData\\Local\\Temp\\GUM",
          ".tmp\\Dropbox"
        ],
        "Image|endswith": ".tmp\\GoogleUpdate.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}