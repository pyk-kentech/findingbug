{
  "name": "Potential CCleanerReactivator.DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\CCleanerReactivator.dll"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Program Files\\CCleaner\\",
          "C:\\Program Files (x86)\\CCleaner\\"
        ],
        "Image|endswith": "\\CCleanerReactivator.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}