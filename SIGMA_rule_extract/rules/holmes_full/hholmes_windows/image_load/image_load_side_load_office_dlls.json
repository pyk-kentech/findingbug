{
  "name": "Microsoft Office DLL Sideload",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageLoaded|endswith": "\\outllib.dll"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|startswith": [
          "C:\\Program Files\\Microsoft Office\\OFFICE",
          "C:\\Program Files (x86)\\Microsoft Office\\OFFICE",
          "C:\\Program Files\\Microsoft Office\\Root\\OFFICE",
          "C:\\Program Files (x86)\\Microsoft Office\\Root\\OFFICE"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}