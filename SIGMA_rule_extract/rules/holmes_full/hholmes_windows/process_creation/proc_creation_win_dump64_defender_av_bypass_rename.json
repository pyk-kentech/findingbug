{
  "name": "Potential Windows Defender AV Bypass Via Dump64.EXE Rename",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": ":\\"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|contains": "\\Microsoft Visual Studio\\",
        "Image|endswith": "\\dump64.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}