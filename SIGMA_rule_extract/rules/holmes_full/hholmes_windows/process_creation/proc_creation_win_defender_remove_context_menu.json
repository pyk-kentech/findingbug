{
  "name": "Windows Defender Context Menu Removed",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\powershell_ise.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\reg.exe"
        ],
        "OriginalFileName": [
          "powershell_ise.EXE",
          "PowerShell.EXE",
          "pwsh.dll",
          "reg.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "del",
          "Remove-Item",
          "ri ",
          "\\shellex\\ContextMenuHandlers\\EPP"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}