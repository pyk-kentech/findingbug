{
  "name": "PUA - Ngrok Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          " tcp 139",
          " tcp 445",
          " tcp 3389",
          " tcp 5985",
          " tcp 5986"
        ],
        "Image|endswith": "ngrok.exe",
        "CommandLine|contains|all": [
          " start ",
          "--all",
          "--config",
          ".yml"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}