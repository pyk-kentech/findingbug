{
  "name": "Potential Dropper Script Execution Via WScript/CScript",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\wscript.exe",
          "\\cscript.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          ":\\Temp\\",
          ":\\Tmp\\",
          ":\\Users\\Public\\",
          ":\\Windows\\Temp\\",
          "\\AppData\\Local\\Temp\\",
          ".js",
          ".jse",
          ".vba",
          ".vbe",
          ".vbs",
          ".wsf"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}