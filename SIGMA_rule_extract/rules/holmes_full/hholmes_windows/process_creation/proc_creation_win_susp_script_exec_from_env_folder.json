{
  "name": "Script Interpreter Execution From Suspicious Folder",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cscript.exe",
          "\\mshta.exe",
          "\\wscript.exe"
        ],
        "CommandLine|contains": [
          " -ep bypass ",
          " -ExecutionPolicy bypass ",
          " -w hidden ",
          "/e:javascript ",
          "/e:Jscript ",
          "/e:vbscript "
        ],
        "OriginalFileName": [
          "cscript.exe",
          "mshta.exe",
          "wscript.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          ":\\Perflogs\\",
          ":\\Users\\Public\\",
          "\\AppData\\Local\\Temp",
          "\\AppData\\Roaming\\Temp",
          "\\Temporary Internet",
          "\\Windows\\Temp"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}