{
  "name": "Renamed PingCastle Binary Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": [
          "PingCastleReporting.exe",
          "PingCastleCloud.exe",
          "PingCastle.exe"
        ],
        "CommandLine|contains": [
          "--no-enum-limit"
        ],
        "CommandLine|contains|all": [
          "--healthcheck",
          "--server "
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\PingCastleReporting.exe",
          "\\PingCastleCloud.exe",
          "\\PingCastle.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}