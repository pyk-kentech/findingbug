{
  "name": "Webshell Hacking Activity Patterns",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\caddy.exe",
          "\\httpd.exe",
          "\\nginx.exe",
          "\\php-cgi.exe",
          "\\w3wp.exe",
          "\\ws_tomcatservice.exe"
        ],
        "ParentImage|contains": [
          "-tomcat-",
          "\\tomcat"
        ],
        "CommandLine|contains|all": [
          "net",
          " localgroup ",
          " administrators ",
          "/add"
        ],
        "Image|endswith": [
          "\\ntdsutil.exe",
          "\\ldifde.exe",
          "\\adfind.exe",
          "\\procdump.exe",
          "\\Nanodump.exe",
          "\\vssadmin.exe",
          "\\fsutil.exe"
        ],
        "CommandLine|contains": [
          " -decode ",
          " -NoP ",
          " -W Hidden ",
          " /decode ",
          " /ticket:",
          " sekurlsa",
          ".dmp full",
          ".downloadfile(",
          ".downloadstring(",
          "FromBase64String",
          "process call create",
          "reg save ",
          "whoami /priv"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}