{
  "name": "Permission Check Via Accesschk.EXE",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Product|endswith": "AccessChk",
        "Description|contains": "Reports effective permissions",
        "Image|endswith": [
          "\\accesschk.exe",
          "\\accesschk64.exe"
        ],
        "OriginalFileName": "accesschk.exe",
        "CommandLine|contains": [
          "uwcqv ",
          "kwsu ",
          "qwsu ",
          "uwdqs "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}