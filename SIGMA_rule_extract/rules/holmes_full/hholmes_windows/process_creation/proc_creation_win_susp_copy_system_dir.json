{
  "name": "Suspicious Copy From or To System Directory",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cmd.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "CommandLine|contains": [
          "copy ",
          "copy-item",
          "cpi ",
          " cp "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "CommandLine|re|i": "\\s['\"]?C:\\Windows\\(System32|SysWOW64|WinSxS)"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}