{
  "name": "Suspicious File Execution From Internet Hosted WebDav Share",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": "\\cmd.exe",
        "OriginalFileName": "Cmd.EXE"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          " net use http",
          "& start /b ",
          "\\DavWWWRoot\\"
        ],
        "CommandLine|contains": [
          ".exe ",
          ".dll ",
          ".bat ",
          ".vbs ",
          ".ps1 "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}