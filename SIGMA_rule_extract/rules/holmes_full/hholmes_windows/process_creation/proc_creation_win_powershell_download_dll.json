{
  "name": "Potential DLL File Download Via PowerShell Invoke-WebRequest",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "Invoke-RestMethod ",
          "Invoke-WebRequest ",
          "IRM ",
          "IWR "
        ],
        "CommandLine|contains|all": [
          "http",
          "OutFile"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "*.dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}