{
  "name": "Shell32 DLL Execution in Suspicious Directory",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\rundll32.exe",
        "OriginalFileName": "RUNDLL32.EXE"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          "shell32.dll",
          "Control_RunDLL"
        ],
        "CommandLine|contains": [
          "%AppData%",
          "%LocalAppData%",
          "%Temp%",
          "%tmp%",
          "\\AppData\\",
          "\\Temp\\",
          "\\Users\\Public\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}