{
  "name": "Potential PowerShell Downgrade Attack",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\powershell.exe",
        "CommandLine|contains": [
          " -version 2 ",
          " -versio 2 ",
          " -versi 2 ",
          " -vers 2 ",
          " -ver 2 ",
          " -ve 2 ",
          " -v 2 "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}