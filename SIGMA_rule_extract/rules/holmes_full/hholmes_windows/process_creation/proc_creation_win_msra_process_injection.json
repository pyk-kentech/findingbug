{
  "name": "Potential Process Injection Via Msra.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\msra.exe",
        "ParentCommandLine|endswith": "msra.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\arp.exe",
          "\\cmd.exe",
          "\\net.exe",
          "\\netstat.exe",
          "\\nslookup.exe",
          "\\route.exe",
          "\\schtasks.exe",
          "\\whoami.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}