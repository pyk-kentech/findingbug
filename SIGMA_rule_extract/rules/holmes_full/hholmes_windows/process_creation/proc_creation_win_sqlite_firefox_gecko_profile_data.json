{
  "name": "SQLite Firefox Profile Data DB Access",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Product": "SQLite",
        "Image|endswith": [
          "\\sqlite.exe",
          "\\sqlite3.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "cookies.sqlite",
          "places.sqlite"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}