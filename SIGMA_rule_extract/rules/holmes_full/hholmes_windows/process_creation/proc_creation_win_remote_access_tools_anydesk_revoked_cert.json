{
  "name": "Remote Access Tool - AnyDesk Execution With Known Revoked Signing Certificate",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\AnyDesk.exe",
        "Description": "AnyDesk",
        "Product": "AnyDesk",
        "Company": "AnyDesk Software GmbH"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "FileVersion|startswith": [
          "7.0.",
          "7.1.",
          "8.0.1",
          "8.0.2",
          "8.0.3",
          "8.0.4",
          "8.0.5",
          "8.0.6",
          "8.0.7"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}