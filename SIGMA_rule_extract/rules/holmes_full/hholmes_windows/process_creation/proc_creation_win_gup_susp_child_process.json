{
  "name": "Suspicious Child Process of Notepad++ Updater - GUP.Exe",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\gup.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cmd.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\cscript.exe",
          "\\wscript.exe",
          "\\mshta.exe"
        ],
        "CommandLine|contains": [
          "bitsadmin",
          "certutil",
          "curl",
          "finger",
          "forfiles",
          "regsvr32",
          "rundll32",
          "wget"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}