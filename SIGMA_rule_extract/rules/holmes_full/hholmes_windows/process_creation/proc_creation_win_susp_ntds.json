{
  "name": "Suspicious Process Patterns NTDS.DIT Exfil",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\NTDSDump.exe",
          "\\NTDSDumpEx.exe"
        ],
        "CommandLine|contains|all": [
          "ntds.dit",
          "system.hiv"
        ],
        "CommandLine|contains": [
          "NTDSgrab.ps1",
          "/c copy ",
          "\\windows\\ntds\\ntds.dit",
          "activate instance ntds",
          "powershell"
        ],
        "ParentImage|contains": [
          "\\apache",
          "\\tomcat",
          "\\AppData\\",
          "\\Temp\\",
          "\\Public\\",
          "\\PerfLogs\\"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "ntds.dit",
          "system.hiv",
          "c:\\exfil\\ntds.dit",
          "c:\\windows\\temp\\data\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}