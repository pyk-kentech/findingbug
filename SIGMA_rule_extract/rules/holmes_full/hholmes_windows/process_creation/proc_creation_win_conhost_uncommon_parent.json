{
  "name": "Conhost Spawned By Uncommon Parent Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\conhost.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ParentImage|endswith": [
          "\\explorer.exe",
          "\\lsass.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe",
          "\\services.exe",
          "\\smss.exe",
          "\\spoolsv.exe",
          "\\svchost.exe",
          "\\userinit.exe",
          "\\wininit.exe",
          "\\winlogon.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}