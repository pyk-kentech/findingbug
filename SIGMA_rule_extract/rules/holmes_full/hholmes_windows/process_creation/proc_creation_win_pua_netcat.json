{
  "name": "PUA - Netcat Suspicious Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\nc.exe",
          "\\ncat.exe",
          "\\netcat.exe"
        ],
        "CommandLine|contains": [
          " -lvp ",
          " -lvnp",
          " -l -v -p ",
          " -lv -p ",
          " -l --proxy-type http ",
          " -vnl --exec ",
          " -vnl -e ",
          " --lua-exec ",
          " --sh-exec "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}