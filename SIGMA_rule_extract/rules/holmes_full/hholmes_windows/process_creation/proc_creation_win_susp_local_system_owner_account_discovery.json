{
  "name": "Local Accounts Discovery",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\whoami.exe",
          "\\quser.exe",
          "\\qwinsta.exe",
          "\\wmic.exe",
          "\\cmdkey.exe",
          "\\cmd.exe",
          "\\net.exe",
          "\\net1.exe"
        ],
        "OriginalFileName": [
          "whoami.exe",
          "quser.exe",
          "qwinsta.exe"
        ],
        "CommandLine|contains|all": [
          "useraccount",
          "get",
          "/c",
          "dir ",
          "\\\\Users\\\\"
        ],
        "CommandLine|contains": [
          " /l",
          " rmdir "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}