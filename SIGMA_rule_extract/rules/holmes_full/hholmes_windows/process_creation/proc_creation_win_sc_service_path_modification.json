{
  "name": "Suspicious Service Path Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\sc.exe",
        "CommandLine|contains|all": [
          "config",
          "binPath"
        ],
        "CommandLine|contains": [
          "powershell",
          "cmd ",
          "mshta",
          "wscript",
          "cscript",
          "rundll32",
          "svchost",
          "dllhost",
          "cmd.exe /c",
          "cmd.exe /k",
          "cmd.exe /r",
          "cmd /c",
          "cmd /k",
          "cmd /r",
          "C:\\Users\\Public",
          "\\Downloads\\",
          "\\Desktop\\",
          "\\Microsoft\\Windows\\Start Menu\\Programs\\Startup\\",
          "C:\\Windows\\TEMP\\",
          "\\AppData\\Local\\Temp"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}