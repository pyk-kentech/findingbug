{
  "name": "MSHTA Execution with Suspicious File Extensions",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\mshta.exe",
        "OriginalFileName": "mshta.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          ".7z",
          ".avi",
          ".bat",
          ".bmp",
          ".conf",
          ".csv",
          ".dll",
          ".doc",
          ".gif",
          ".gz",
          ".ini",
          ".jpe",
          ".jpg",
          ".json",
          ".lnk",
          ".log",
          ".mkv",
          ".mp3",
          ".mp4",
          ".pdf",
          ".png",
          ".ppt",
          ".rar",
          ".rtf",
          ".svg",
          ".tar",
          ".tmp",
          ".txt",
          ".xls",
          ".xml",
          ".yaml",
          ".yml",
          ".zip",
          "vbscript"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}