{
  "name": "New DMSA Service Account Created in Specific OUs",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\powershell_ise.exe"
        ],
        "OriginalFileName": [
          "powershell.exe",
          "pwsh.dll",
          "powershell_ise.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          "New-ADServiceAccount",
          "-CreateDelegatedServiceAccount",
          "-path"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}