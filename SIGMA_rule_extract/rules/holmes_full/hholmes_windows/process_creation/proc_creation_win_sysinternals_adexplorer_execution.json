{
  "name": "Active Directory Database Snapshot Via ADExplorer",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\ADExp.exe",
          "\\ADExplorer.exe",
          "\\ADExplorer64.exe",
          "\\ADExplorer64a.exe"
        ],
        "OriginalFileName": "AdExp",
        "Description": "Active Directory Editor",
        "Product": "Sysinternals ADExplorer"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}