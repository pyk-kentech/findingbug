{
  "name": "Uncommon Child Process Of Appvlp.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\appvlp.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          ":\\Windows\\SysWOW64\\rundll32.exe",
          ":\\Windows\\System32\\rundll32.exe"
        ],
        "Image|contains": [
          ":\\Program Files\\Microsoft Office"
        ],
        "Image|endswith|all": [
          "\\msoasb.exe",
          "\\SkypeSrv\\SKYPESERVER.EXE",
          "\\MSOUC.EXE"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}