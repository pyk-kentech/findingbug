{
  "name": "PUA - PingCastle Execution From Potentially Suspicious Parent",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentCommandLine|contains": [
          ".bat",
          ".chm",
          ".cmd",
          ".hta",
          ".htm",
          ".html",
          ".js",
          ".lnk",
          ".ps1",
          ".vbe",
          ".vbs",
          ".wsf"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\PingCastle.exe",
        "OriginalFileName": "PingCastle.exe",
        "Product": "Ping Castle",
        "CommandLine|contains": [
          "--no-enum-limit"
        ],
        "CommandLine|contains|all": [
          "--healthcheck",
          "--server "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}