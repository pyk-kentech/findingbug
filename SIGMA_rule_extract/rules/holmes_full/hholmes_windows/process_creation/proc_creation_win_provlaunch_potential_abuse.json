{
  "name": "Potential Provlaunch.EXE Binary Proxy Execution Abuse",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\provlaunch.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\calc.exe",
          "\\cmd.exe",
          "\\cscript.exe",
          "\\mshta.exe",
          "\\notepad.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe",
          "\\wscript.exe"
        ],
        "Image|contains": [
          ":\\PerfLogs\\",
          ":\\Temp\\",
          ":\\Users\\Public\\",
          "\\AppData\\Temp\\",
          "\\Windows\\System32\\Tasks\\",
          "\\Windows\\Tasks\\",
          "\\Windows\\Temp\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}