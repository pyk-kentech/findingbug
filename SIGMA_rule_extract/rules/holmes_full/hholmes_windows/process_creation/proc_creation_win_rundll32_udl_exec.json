{
  "name": "Potentially Suspicious Rundll32.EXE Execution of UDL File",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\explorer.exe",
        "Image|endswith": "\\rundll32.exe",
        "OriginalFileName": "RUNDLL32.EXE"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          "oledb32.dll",
          ",OpenDSLFile ",
          "\\\\Users\\\\*\\\\Downloads\\\\"
        ],
        "CommandLine|endswith": ".udl"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}