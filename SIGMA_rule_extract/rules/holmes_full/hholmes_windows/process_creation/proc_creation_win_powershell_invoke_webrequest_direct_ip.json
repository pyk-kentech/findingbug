{
  "name": "Suspicious Invoke-WebRequest Execution With DirectIP",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\powershell_ise.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "OriginalFileName": [
          "powershell_ise.EXE",
          "PowerShell.EXE",
          "pwsh.dll"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "curl ",
          "Invoke-RestMethod",
          "Invoke-WebRequest",
          " irm ",
          "iwr ",
          "wget "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}