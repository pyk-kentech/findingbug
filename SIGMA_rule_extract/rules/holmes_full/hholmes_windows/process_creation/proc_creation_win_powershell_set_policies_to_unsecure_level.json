{
  "name": "Change PowerShell Policies to an Insecure Level",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": [
          "powershell_ise.exe",
          "PowerShell.EXE",
          "pwsh.dll"
        ],
        "Image|endswith": [
          "\\powershell_ise.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "-executionpolicy ",
          " -ep ",
          " -exec "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}