{
  "name": "Use NTFS Short Name in Image",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          "~1.bat",
          "~1.dll",
          "~1.exe",
          "~1.hta",
          "~1.js",
          "~1.msi",
          "~1.ps1",
          "~1.tmp",
          "~1.vbe",
          "~1.vbs",
          "~2.bat",
          "~2.dll",
          "~2.exe",
          "~2.hta",
          "~2.js",
          "~2.msi",
          "~2.ps1",
          "~2.tmp",
          "~2.vbe",
          "~2.vbs"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}