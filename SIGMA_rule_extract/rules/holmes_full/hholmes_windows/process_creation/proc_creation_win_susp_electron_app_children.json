{
  "name": "Suspicious Electron Application Child Processes",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\chrome.exe",
          "\\discord.exe",
          "\\GitHubDesktop.exe",
          "\\keybase.exe",
          "\\msedge.exe",
          "\\msedgewebview2.exe",
          "\\msteams.exe",
          "\\slack.exe",
          "\\teams.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cmd.exe",
          "\\cscript.exe",
          "\\mshta.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\regsvr32.exe",
          "\\whoami.exe",
          "\\wscript.exe"
        ],
        "Image|contains": [
          ":\\ProgramData\\",
          ":\\Temp\\",
          "\\AppData\\Local\\Temp\\",
          "\\Users\\Public\\",
          "\\Windows\\Temp\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}