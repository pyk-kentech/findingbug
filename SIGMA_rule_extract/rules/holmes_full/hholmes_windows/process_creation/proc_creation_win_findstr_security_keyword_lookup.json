{
  "name": "Security Tools Keyword Lookup Via Findstr.EXE",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\find.exe",
          "\\findstr.exe"
        ],
        "OriginalFileName": [
          "FIND.EXE",
          "FINDSTR.EXE"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|endswith": [
          " avira",
          " avira\"",
          " cb",
          " cb\"",
          " cylance",
          " cylance\"",
          " defender",
          " defender\"",
          " kaspersky",
          " kaspersky\"",
          " kes",
          " kes\"",
          " mc",
          " mc\"",
          " sec",
          " sec\"",
          " sentinel",
          " sentinel\"",
          " symantec",
          " symantec\"",
          " virus",
          " virus\""
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}