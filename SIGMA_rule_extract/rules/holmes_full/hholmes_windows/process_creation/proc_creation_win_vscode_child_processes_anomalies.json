{
  "name": "Potentially Suspicious Child Process Of VsCode",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\code.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\calc.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe",
          "\\cscript.exe",
          "\\wscript.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\cmd.exe"
        ],
        "CommandLine|contains": [
          "Invoke-Expressions",
          "IEX",
          "Invoke-Command",
          "ICM",
          "DownloadString",
          "rundll32",
          "regsvr32",
          "wscript",
          "cscript"
        ],
        "Image|contains": [
          ":\\Users\\Public\\",
          ":\\Windows\\Temp\\",
          ":\\Temp\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}