{
  "name": "Copy From Or To Admin Share Or Sysvol Folder",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "copy-item",
          "copy ",
          "cpi ",
          " cp ",
          "move ",
          " move-item",
          " mi ",
          " mv "
        ],
        "Image|endswith": [
          "\\robocopy.exe",
          "\\xcopy.exe"
        ],
        "OriginalFileName": [
          "powershell_ise.exe",
          "PowerShell.EXE",
          "pwsh.dll"
        ],
        "Image|contains": [
          "\\powershell_ise.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
