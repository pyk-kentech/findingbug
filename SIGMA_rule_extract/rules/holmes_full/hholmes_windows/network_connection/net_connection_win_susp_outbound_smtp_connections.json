{
  "name": "Suspicious Outbound SMTP Connections",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\thunderbird.exe",
          "\\outlook.exe"
        ],
        "Image|startswith": [
          "C:\\Program Files\\Microsoft\\Exchange Server\\",
          "C:\\Program Files\\WindowsApps\\microsoft.windowscommunicationsapps_"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationPort": [
          25,
          587,
          465,
          2525
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}