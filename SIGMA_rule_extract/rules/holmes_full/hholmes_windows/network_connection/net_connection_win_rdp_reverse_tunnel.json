{
  "name": "RDP Over Reverse SSH Tunnel",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\svchost.exe",
        "Initiated": "true",
        "SourcePort": 3389
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationIp|cidr": [
          "127.0.0.0/8",
          "::1/128"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}