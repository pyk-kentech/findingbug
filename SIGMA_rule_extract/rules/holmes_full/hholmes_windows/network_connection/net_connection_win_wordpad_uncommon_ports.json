{
  "name": "Suspicious Wordpad Outbound Connections",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\wordpad.exe"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationPort": [
          80,
          139,
          443,
          445,
          465,
          587,
          993,
          995
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}