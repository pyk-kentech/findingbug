{
  "name": "Suspicious Non-Browser Network Communication With Google API",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "DestinationHostname|contains": [
          "drive.googleapis.com",
          "oauth2.googleapis.com",
          "sheets.googleapis.com",
          "www.googleapis.com"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}