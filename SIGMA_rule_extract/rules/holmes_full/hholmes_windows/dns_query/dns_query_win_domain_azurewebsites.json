{
  "name": "DNS Query To AzureWebsites.NET By Non-Browser Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Event",
      "attributes": {
        "Image|endswith": [
          "chrome.exe",
          "firefox.exe",
          "iexplore.exe",
          "MicrosoftEdge.exe",
          "msedge.exe",
          "MsMpEng.exe",
          "MsSense.exe",
          "brave.exe",
          "maxthon.exe",
          "opera.exe",
          "seamonkey.exe",
          "vivaldi.exe",
          "whale.exe",
          "Waterfox.exe",
          "Midori Next Generation.exe",
          "slimbrowser.exe",
          "Flock.exe",
          "Phoebe.exe",
          "falkon.exe",
          "avant.exe"
        ],
        "Image|startswith": [
          "C:\\Program Files\\Google\\Chrome\\Application\\",
          "C:\\Program Files (x86)\\Google\\Chrome\\Application\\",
          "C:\\Program Files\\Mozilla Firefox\\",
          "C:\\Program Files (x86)\\Mozilla Firefox\\",
          "C:\\Program Files (x86)\\Internet Explorer\\",
          "C:\\Program Files\\Internet Explorer\\",
          "C:\\Program Files (x86)\\Microsoft\\EdgeWebView\\Application\\",
          "C:\\Program Files\\Microsoft\\Edge\\Application\\",
          "C:\\Program Files (x86)\\Microsoft\\EdgeCore\\",
          "C:\\Program Files\\Microsoft\\EdgeCore\\",
          "C:\\Program Files\\BraveSoftware\\",
          "\\AppData\\Local\\Maxthon\\",
          "\\AppData\\Local\\Programs\\Opera\\",
          "C:\\Program Files\\SeaMonkey\\",
          "C:\\Program Files (x86)\\SeaMonkey\\",
          "\\AppData\\Local\\Vivaldi\\",
          "C:\\Program Files\\Naver\\Naver Whale\\",
          "C:\\Program Files (x86)\\Naver\\Naver Whale\\",
          "\\Tor Browser\\",
          "C:\\Program Files\\Waterfox\\",
          "C:\\Program Files (x86)\\Waterfox\\",
          "\\AppData\\Local\\Programs\\midori-ng\\",
          "C:\\Program Files\\SlimBrowser\\",
          "C:\\Program Files (x86)\\SlimBrowser\\",
          "\\AppData\\Local\\Flock\\",
          "\\AppData\\Local\\Phoebe\\",
          "C:\\Program Files\\Falkon\\",
          "C:\\Program Files (x86)\\Falkon\\",
          "C:\\Program Files (x86)\\Avant Browser\\",
          "C:\\Program Files\\Avant Browser\\"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "QueryName|endswith": "azurewebsites.net"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}