{
  "name": "TeamViewer Domain Query By Non-TeamViewer Application",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Event",
      "attributes": {
        "Image|contains": "TeamViewer"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "QueryName": [
          "taf.teamviewer.com",
          "udp.ping.teamviewer.com"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}