{
  "name": "Suspicious Cobalt Strike DNS Beaconing - Sysmon",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Event",
      "attributes": {
        "QueryName|startswith": [
          "'aaa.stage.'",
          "'post.1'"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "QueryName|contains": "'.stage.123456.'"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}