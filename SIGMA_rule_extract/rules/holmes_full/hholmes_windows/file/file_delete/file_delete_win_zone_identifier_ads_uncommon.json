{
  "name": "ADS Zone.Identifier Deleted By Uncommon Application",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\pwsh.exe",
          "\\explorer.exe",
          "\\powershell.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": ":Zone.Identifier"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}