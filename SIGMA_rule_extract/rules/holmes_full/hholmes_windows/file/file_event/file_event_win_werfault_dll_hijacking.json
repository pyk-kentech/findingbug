{
  "name": "Creation of WerFault.exe/Wer.dll in Unusual Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          "\\WerFault.exe",
          "\\wer.dll"
        ],
        "TargetFilename|startswith": [
          "C:\\Windows\\SoftwareDistribution\\",
          "C:\\Windows\\System32\\",
          "C:\\Windows\\SysWOW64\\",
          "C:\\Windows\\WinSxS\\",
          "C:\\Windows\\UUS\\arm64\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}