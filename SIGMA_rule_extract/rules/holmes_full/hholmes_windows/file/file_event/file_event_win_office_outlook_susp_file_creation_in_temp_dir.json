{
  "name": "Suspicious File Created in Outlook Temporary Directory",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "TargetFilename|endswith": [
          ".cpl",
          ".hta",
          ".iso",
          ".rdp",
          ".svg",
          ".vba",
          ".vbe",
          ".vbs"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\AppData\\Local\\Packages\\Microsoft.Outlook_",
          "\\AppData\\Local\\Microsoft\\Olk\\Attachments\\",
          "\\AppData\\Local\\Microsoft\\Windows\\Content.Outlook\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}