{
  "name": "Windows Shell/Scripting Application File Write to Suspicious Folder",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\bash.exe",
          "\\cmd.exe",
          "\\cscript.exe",
          "\\msbuild.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\sh.exe",
          "\\wscript.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|startswith": [
          "C:\\PerfLogs\\",
          "C:\\Users\\Public\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}