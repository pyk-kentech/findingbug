{
  "name": "Legitimate Application Dropped Archive",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\winword.exe",
          "\\excel.exe",
          "\\powerpnt.exe",
          "\\msaccess.exe",
          "\\mspub.exe",
          "\\eqnedt32.exe",
          "\\visio.exe",
          "\\wordpad.exe",
          "\\wordview.exe",
          "\\certutil.exe",
          "\\certoc.exe",
          "\\CertReq.exe",
          "\\Desktopimgdownldr.exe",
          "\\esentutl.exe",
          "\\finger.exe",
          "\\notepad.exe",
          "\\AcroRd32.exe",
          "\\RdrCEF.exe",
          "\\mshta.exe",
          "\\hh.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".zip",
          ".rar",
          ".7z",
          ".diagcab",
          ".appx"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}