{
  "name": "Windows Binaries Write Suspicious Extensions",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\csrss.exe",
          "\\lsass.exe",
          "\\RuntimeBroker.exe",
          "\\sihost.exe",
          "\\smss.exe",
          "\\wininit.exe",
          "\\winlogon.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".bat",
          ".dll",
          ".exe",
          ".hta",
          ".iso",
          ".ps1",
          ".txt",
          ".vbe",
          ".vbs"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}