{
  "name": "WinSxS Executable File Creation By Non-System Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Windows\\Systems32\\",
          "C:\\Windows\\SysWOW64\\",
          "C:\\Windows\\WinSxS\\"
        ],
        "TargetFilename|startswith": "C:\\Windows\\WinSxS\\",
        "TargetFilename|endswith": ".exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}