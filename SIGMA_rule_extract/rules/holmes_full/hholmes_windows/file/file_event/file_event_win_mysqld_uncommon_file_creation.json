{
  "name": "Uncommon File Creation By Mysql Daemon Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\mysqld.exe",
          "\\mysqld-nt.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".bat",
          ".dat",
          ".dll",
          ".exe",
          ".ps1",
          ".psm1",
          ".vbe",
          ".vbs"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}