{
  "name": "Potential Persistence Via Microsoft Office Startup Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\WINWORD.exe",
          "\\EXCEL.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\Microsoft\\Word\\STARTUP",
          "\\Office",
          "\\Program Files",
          "\\STARTUP",
          "\\Microsoft\\Excel\\XLSTART"
        ],
        "TargetFilename|endswith": [
          ".doc",
          ".docm",
          ".docx",
          ".dot",
          ".dotm",
          ".rtf",
          ".xls",
          ".xlsm",
          ".xlsx",
          ".xlt",
          ".xltm"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}