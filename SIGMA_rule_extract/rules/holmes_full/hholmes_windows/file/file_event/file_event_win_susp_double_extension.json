{
  "name": "Suspicious Double Extension Files",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".rar.exe",
          ".zip.exe"
        ],
        "TargetFilename|contains": [
          ".doc.",
          ".docx.",
          ".gif.",
          ".jpeg.",
          ".jpg.",
          ".mp3.",
          ".mp4.",
          ".pdf.",
          ".png.",
          ".ppt.",
          ".pptx.",
          ".rtf.",
          ".svg.",
          ".txt.",
          ".xls.",
          ".xlsx."
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}