{
  "name": "Potential Persistence Via Notepad++ Plugins",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\Notepad++\\updater\\gup.exe",
          "\\target.exe",
          "Installer.x64.exe"
        ],
        "Image|startswith": "C:\\Users\\",
        "Image|contains": "\\npp."
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\Notepad++\\plugins\\",
        "TargetFilename|endswith": ".dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}