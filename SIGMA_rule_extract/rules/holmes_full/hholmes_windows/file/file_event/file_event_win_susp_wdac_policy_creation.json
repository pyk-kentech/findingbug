{
  "name": "Potentially Suspicious WDAC Policy File Creation",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          "Copy-Item -Path",
          "-Destination"
        ],
        "CommandLine|contains": "CiTool --update-policy"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\Windows\\System32\\CodeIntegrity\\"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}