{
  "name": "Microsoft Teams Sensitive File Access By Uncommon Applications",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\Microsoft\\Teams\\current\\Teams.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "FileName|contains": [
          "\\Microsoft\\Teams\\Cookies",
          "\\Microsoft\\Teams\\Local Storage\\leveldb"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}