{
  "name": "Access To Crypto Currency Wallets By Uncommon Applications",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Program Files (x86)\\",
          "C:\\Program Files\\",
          "C:\\Windows\\system32\\",
          "C:\\Windows\\SysWOW64\\"
        ],
        "Image|endswith": [
          "\\MpCopyAccelerator.exe",
          "\\MsMpEng.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "FileName|contains": [
          "\\AppData\\Roaming\\Ethereum\\keystore\\",
          "\\AppData\\Roaming\\EthereumClassic\\keystore\\",
          "\\AppData\\Roaming\\monero\\wallets\\"
        ],
        "FileName|endswith": [
          "\\AppData\\Roaming\\Bitcoin\\wallet.dat",
          "\\AppData\\Roaming\\BitcoinABC\\wallet.dat",
          "\\AppData\\Roaming\\BitcoinSV\\wallet.dat",
          "\\AppData\\Roaming\\DashCore\\wallet.dat",
          "\\AppData\\Roaming\\DogeCoin\\wallet.dat",
          "\\AppData\\Roaming\\Litecoin\\wallet.dat",
          "\\AppData\\Roaming\\Ripple\\wallet.dat",
          "\\AppData\\Roaming\\Zcash\\wallet.dat"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}