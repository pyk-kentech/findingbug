{
  "name": "Access to Browser Login Data",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains|all": [
          "Copy-Item",
          "-Destination"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "\\Opera Software\\Opera Stable\\Login Data",
          "\\Mozilla\\Firefox\\Profiles",
          "\\Microsoft\\Edge\\User Data\\Default",
          "\\Google\\Chrome\\User Data\\Default\\Login Data",
          "\\Google\\Chrome\\User Data\\Default\\Login Data For Account"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}