{
  "name": "Deletion of Volume Shadow Copies via WMI with PowerShell - PS Script",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "Get-WmiObject",
          "gwmi",
          "Get-CimInstance",
          "gcim"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "Win32_ShadowCopy",
          ".Delete()",
          "Remove-WmiObject",
          "rwmi",
          "Remove-CimInstance",
          "rcim"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}