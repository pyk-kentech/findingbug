{
  "name": "Potential Persistence Via PowerShell User Profile Using Add-Content",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "Add-Content $profile",
          "-Value \"IEX ",
          "-Value \"Invoke-Expression",
          "-Value \"Invoke-WebRequest",
          "-Value \"Start-Process",
          "-Value 'IEX ",
          "-Value 'Invoke-Expression",
          "-Value 'Invoke-WebRequest",
          "-Value 'Start-Process"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}