{
  "name": "Tamper Windows Defender Remove-MpPreference - ScriptBlockLogging",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": "Remove-MpPreference"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "-ControlledFolderAccessProtectedFolders ",
          "-AttackSurfaceReductionRules_Ids ",
          "-AttackSurfaceReductionRules_Actions ",
          "-CheckForSignaturesBeforeRunningScan "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}