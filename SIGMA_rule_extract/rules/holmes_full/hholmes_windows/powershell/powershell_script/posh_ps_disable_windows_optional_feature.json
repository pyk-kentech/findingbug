{
  "name": "Disable-WindowsOptionalFeature Command PowerShell",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains|all": [
          "Disable-WindowsOptionalFeature",
          "-Online",
          "-FeatureName"
        ],
        "ScriptBlockText|contains": [
          "Windows-Defender-Gui",
          "Windows-Defender-Features",
          "Windows-Defender",
          "Windows-Defender-ApplicationGuard"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}