{
  "name": "Zip A Folder With PowerShell For Staging In Temp - PowerShell",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "command_line": "Compress-Archive -Path*-DestinationPath $env:TEMP|endswith"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "*:\temp\\*"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}