{
  "name": "Suspicious Microsoft Office Child Process - MacOS",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|contains": [
          "Microsoft Word",
          "Microsoft Excel",
          "Microsoft PowerPoint",
          "Microsoft OneNote"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/bash",
          "/curl",
          "/dash",
          "/fish",
          "/osacompile",
          "/osascript",
          "/sh",
          "/zsh",
          "/python",
          "/python3",
          "/wget"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}