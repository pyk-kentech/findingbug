{
  "name": "Antivirus Password Dumper Detection",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Signature|startswith": "PWS",
        "Signature|contains": [
          "Certify",
          "DCSync",
          "DumpCreds",
          "DumpLsass",
          "DumpPert",
          "HTool/WCE",
          "Kekeo",
          "Lazagne",
          "LsassDump",
          "Mimikatz",
          "MultiDump",
          "Nanodump",
          "NativeDump",
          "Outflank",
          "PShlSpy",
          "PSWTool",
          "PWCrack",
          "PWDump",
          "PWS.",
          "PWSX",
          "pypykatz",
          "Rubeus",
          "SafetyKatz",
          "SecurityTool",
          "SharpChrome",
          "SharpDPAPI",
          "SharpDump",
          "SharpKatz",
          "SharpS.",
          "ShpKatz",
          "TrickDump"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}