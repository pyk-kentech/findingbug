{
  "name": "Local System Accounts Discovery - Linux",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/lastlog",
          "/cat",
          "/ed",
          "/head",
          "/more",
          "/nano",
          "/tail",
          "/vi",
          "/vim",
          "/less",
          "/emacs",
          "/sqlite3",
          "/makemap",
          "/id",
          "/lsof"
        ],
        "CommandLine|contains": [
          "'x:0:'",
          "/etc/passwd",
          "/etc/shadow",
          "/etc/sudoers",
          "/etc/spwd.db",
          "/etc/pwd.db",
          "/etc/master.passwd",
          "-u"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}