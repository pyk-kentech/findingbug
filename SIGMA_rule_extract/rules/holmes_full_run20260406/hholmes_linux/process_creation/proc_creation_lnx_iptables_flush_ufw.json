{
  "name": "Flush Iptables Ufw Chain",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/iptables",
          "/xtables-legacy-multi",
          "/iptables-legacy-multi",
          "/ip6tables",
          "/ip6tables-legacy-multi"
        ],
        "CommandLine|contains": [
          "-F",
          "-Z",
          "-X",
          "ufw-logging-deny",
          "ufw-logging-allow",
          "ufw6-logging-deny",
          "ufw6-logging-allow"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}