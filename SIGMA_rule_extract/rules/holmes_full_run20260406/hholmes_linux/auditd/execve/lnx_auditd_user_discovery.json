{
  "name": "System Owner or User Discovery - Linux",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "type": "EXECVE",
        "a0": [
          "hostname",
          "id",
          "last",
          "uname",
          "users",
          "w",
          "who",
          "whoami"
        ]
      }
    },
    "object": {
      "type": "Event",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}