{
  "name": "Program Executions in Suspicious Folders",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "/tmp/*",
          "/var/www/*",
          "/home/*/public_html/*",
          "/usr/local/apache2/*",
          "/usr/local/httpd/*",
          "/var/apache/*",
          "/srv/www/*",
          "/home/httpd/html/*",
          "/srv/http/*",
          "/usr/share/nginx/html/*",
          "/var/lib/pgsql/data/*",
          "/usr/local/mysql/data/*",
          "/var/lib/mysql/*",
          "/var/vsftpd/*",
          "/etc/bind/*",
          "/var/named/*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}