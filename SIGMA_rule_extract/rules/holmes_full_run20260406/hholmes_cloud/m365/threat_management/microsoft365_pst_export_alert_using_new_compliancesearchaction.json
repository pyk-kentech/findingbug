{
  "name": "PST Export Alert Using New-ComplianceSearchAction",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {}
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "eventSource": "SecurityComplianceCenter",
        "Payload|contains|all": [
          "New-ComplianceSearchAction",
          "Export",
          "pst"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}