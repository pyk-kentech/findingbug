{
  "name": "User Added to an Administrator's Azure AD Role",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "Operation": "Add member to role.",
        "Workload": "AzureActiveDirectory",
        "ModifiedProperties{}.NewValue|endswith": [
          "Admins",
          "Administrator"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}