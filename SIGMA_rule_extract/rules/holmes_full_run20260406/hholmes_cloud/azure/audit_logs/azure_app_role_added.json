{
  "name": "App Assigned To Azure RBAC/Microsoft Entra Role",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "targetResources.type": "Service Principal",
        "properties.message": [
          "Add member to role",
          "Add eligible member to role",
          "Add scoped member to role"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}