{
  "name": "Google Workspace User Granted Admin Privileges",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {}
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "eventService": "admin.googleapis.com",
        "eventName": [
          "GRANT_DELEGATED_ADMIN_PRIVILEGES",
          "GRANT_ADMIN_PRIVILEGE"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}