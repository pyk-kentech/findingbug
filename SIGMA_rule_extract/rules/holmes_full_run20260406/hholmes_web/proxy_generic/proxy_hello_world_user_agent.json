{
  "name": "Potential Hello-World Scraper Botnet Activity",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Event",
      "attributes": {
        "c-useragent": "Hello-World/1.0",
        "cs-method": "GET"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationIp": "*",
        "DestinationPort": "*"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}