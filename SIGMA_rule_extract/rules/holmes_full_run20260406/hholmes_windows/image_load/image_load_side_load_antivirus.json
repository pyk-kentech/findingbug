{
  "name": "Potential Antivirus Software DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded": [
          "*\\log.dll",
          "*\\qrt.dll",
          "*\\ashldres.dll",
          "*\\lockdown.dll",
          "*\\vsodscpl.dll",
          "*\\vftrace.dll",
          "*\\wsc.dll",
          "*\\DLPPREM32.dll",
          "*\\tmdbglog.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}