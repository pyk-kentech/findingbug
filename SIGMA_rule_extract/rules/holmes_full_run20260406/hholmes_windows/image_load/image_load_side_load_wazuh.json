{
  "name": "Potential Wazuh Security Platform DLL Sideloading",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|endswith": [
          "\\libwazuhshared.dll",
          "\\libwinpthread-1.dll"
        ],
        "ImageLoaded|startswith": [
          "C:\\Program Files\\",
          "C:\\Program Files (x86)\\"
        ],
        "ImageLoaded|contains": [
          "\\AppData\\Local\\",
          "\\ProgramData\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}