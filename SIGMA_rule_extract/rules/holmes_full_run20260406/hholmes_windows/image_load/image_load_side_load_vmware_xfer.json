{
  "name": "Potential DLL Sideloading Via VMware Xfer",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "\\VMwareXferlogs.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded": "C:\\Program Files\\VMware\\*\\glib-2.0.dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}