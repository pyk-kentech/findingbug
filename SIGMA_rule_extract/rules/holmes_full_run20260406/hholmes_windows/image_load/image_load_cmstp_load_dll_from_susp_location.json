{
  "name": "DLL Loaded From Suspicious Location Via Cmspt.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "\\cmstp.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImageLoaded|contains": [
          "\\PerfLogs\\",
          "\\ProgramData\\",
          "\\Users\\",
          "\\Windows\\Temp\\",
          "C:\\Temp\\"
        ],
        "ImageLoaded|endswith": [
          ".dll",
          ".ocx"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}