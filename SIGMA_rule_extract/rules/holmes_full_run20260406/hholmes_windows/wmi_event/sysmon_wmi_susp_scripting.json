{
  "name": "Suspicious Scripting in a WMI Consumer",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "Destination": [
          "*new-object*net.webclient*.downloadstring*",
          "*new-object*net.webclient*.downloadfile*",
          "*iex(*-nop*-noprofile*-decode*-enc*WScript.Shell*System.Security.Cryptography.FromBase64Transform*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}