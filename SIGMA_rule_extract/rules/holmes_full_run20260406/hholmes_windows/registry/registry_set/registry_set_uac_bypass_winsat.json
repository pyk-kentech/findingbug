{
  "name": "UAC Bypass Abusing Winsat Path Parsing - Registry",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\Root\\InventoryApplicationFile\\winsat.exe|",
        "TargetObject|endswith": "\\LowerCaseLongPath",
        "Details|startswith": "c:\\users\\",
        "Details|endswith": "\\appdata\\local\\temp\\system32\\winsat.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}