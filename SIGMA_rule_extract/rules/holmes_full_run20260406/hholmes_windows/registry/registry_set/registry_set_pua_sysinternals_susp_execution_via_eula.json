{
  "name": "PUA - Sysinternals Tools Execution - Registry",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Active Directory Explorer",
          "\\Handle",
          "\\LiveKd",
          "\\Process Explorer",
          "\\ProcDump",
          "\\PsExec",
          "\\PsLoglist",
          "\\PsPasswd",
          "\\SDelete",
          "\\Sysinternals"
        ],
        "TargetObject|endswith": [
          "\\EulaAccepted"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}