{
  "name": "Potential CobaltStrike Service Installations - Registry",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\System\\CurrentControlSet\\Services"
        ],
        "Details|contains|all": [
          "ADMIN$",
          ".exe",
          "%COMSPEC%",
          "start",
          "powershell"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}