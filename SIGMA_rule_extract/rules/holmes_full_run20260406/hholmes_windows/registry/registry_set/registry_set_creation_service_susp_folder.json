{
  "name": "Service Binary in Suspicious Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": [
          "*\\Users\\Public\\*",
          "*\\Perflogs\\*",
          "*\\ADMIN$\\*",
          "*\\Temp\\*"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|startswith": "HKLM\\System\\CurrentControlSet\\Services\\",
        "TargetObject|endswith": "\\Start",
        "Details": [
          "DWORD (0x00000000)",
          "DWORD (0x00000001)",
          "DWORD (0x00000002)"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}