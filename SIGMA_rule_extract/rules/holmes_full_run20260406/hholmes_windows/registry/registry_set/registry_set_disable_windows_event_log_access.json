{
  "name": "Windows Event Log Access Tampering Via Registry",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": "C:\\Windows\\WinSxS\\",
        "Image|endswith": "\\TiWorker.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\SYSTEM\\CurrentControlSet\\Services\\EventLog\\",
          "\\Policies\\Microsoft\\Windows\\EventLog\\",
          "\\Microsoft\\Windows\\CurrentVersion\\WINEVT\\Channels"
        ],
        "TargetObject|endswith": [
          "\\CustomSD",
          "\\ChannelAccess"
        ],
        "Details|contains": [
          "D:(D;",
          "D:("
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}