{
  "name": "Registry Modification for OCI DLL Redirection",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|endswith": [
          "\\SOFTWARE\\Microsoft\\MSDTC\\MTxOCI\\OracleOciLib",
          "\\SOFTWARE\\Microsoft\\MSDTC\\MTxOCI\\OracleOciLibPath"
        ],
        "Details|contains": [
          "oci.dll",
          "%SystemRoot%\\System32\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}