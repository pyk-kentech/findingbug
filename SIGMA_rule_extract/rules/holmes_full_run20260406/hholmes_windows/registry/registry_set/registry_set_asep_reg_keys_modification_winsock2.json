{
  "name": "WinSock2 Autorun Keys Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": [
          "C:\\Windows\\System32\\MsiExec.exe",
          "C:\\Windows\\syswow64\\MsiExec.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\System\\CurrentControlSet\\Services\\WinSock2\\Parameters",
          "\\Protocol_Catalog9\\Catalog_Entries",
          "\\NameSpace_Catalog5\\Catalog_Entries"
        ],
        "Details": "(Empty)"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}