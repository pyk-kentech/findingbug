{
  "name": "WFP Filter Added via Registry",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": [
          "C:\\Windows\\System32\\svchost.exe",
          "C:\\Windows\\SysWOW64\\svchost.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\BFE\\Parameters\\Policy\\Persistent\\Filter\\"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}