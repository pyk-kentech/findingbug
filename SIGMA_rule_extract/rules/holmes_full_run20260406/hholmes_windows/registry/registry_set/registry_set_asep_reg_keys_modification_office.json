{
  "name": "Office Autorun Keys Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Program Files\\Microsoft Office\\",
          "C:\\Program Files (x86)\\Microsoft Office\\",
          "C:\\Windows\\System32\\msiexec.exe",
          "C:\\Windows\\System32\\regsvr32.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Software\\Wow6432Node\\Microsoft\\Office",
          "\\Software\\Microsoft\\Office",
          "\\Word\\Addins",
          "\\PowerPoint\\Addins",
          "\\Outlook\\Addins",
          "\\Onenote\\Addins",
          "\\Excel\\Addins",
          "\\Access\\Addins",
          "test\\Special\\Perf"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}