{
  "name": "New RUN Key Pointing to Suspicious Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",
          "\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Run",
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\Run"
        ],
        "Details|contains": [
          ":\\Perflogs",
          ":\\ProgramData",
          ":\\Windows\\Temp",
          ":\\Temp",
          "\\AppData\\Local\\Temp",
          "\\AppData\\Roaming",
          ":\\$Recycle.bin",
          ":\\Users\\Default",
          ":\\Users\\public",
          "%temp%",
          "%tmp%",
          "%Public%",
          "%AppData%"
        ],
        "Details|contains|all": [
          "rundll32.exe ",
          "C:\\WINDOWS\\system32\\advpack.dll,DelNodeRunDLL32"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}