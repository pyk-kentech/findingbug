{
  "name": "Potential Persistence Via Custom Protocol Handler",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Program Files (x86)\\",
          "C:\\Program Files\\",
          "C:\\Windows\\System32\\",
          "C:\\Windows\\SysWOW64\\"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|startswith": "HKCR\\",
        "Details|startswith": "URL:"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}