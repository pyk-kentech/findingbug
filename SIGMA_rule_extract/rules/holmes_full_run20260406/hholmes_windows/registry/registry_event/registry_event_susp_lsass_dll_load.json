{
  "name": "DLL Load via LSASS",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "C:\\Windows\\system32\\lsass.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\CurrentControlSet\\Services\\NTDS\\DirectoryServiceExtPt",
          "\\CurrentControlSet\\Services\\NTDS\\LsaDbExtPt"
        ],
        "Details": [
          "%%systemroot%%\\system32\\ntdsa.dll",
          "%%systemroot%%\\system32\\lsadb.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}