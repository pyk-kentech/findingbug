{
  "name": "Security Support Provider (SSP) Added to LSA Configuration",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": [
          "C:\\Windows\\system32\\msiexec.exe",
          "C:\\Windows\\syswow64\\MsiExec.exe"
        ]
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|endswith": [
          "\\Control\\Lsa\\Security Packages",
          "\\Control\\Lsa\\OSConfig\\Security Packages"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}