{
  "name": "Suspicious Scheduled Task Update",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*regsvr32*",
          "*rundll32*",
          "*cmd.exe</Command>*",
          "*cmd</Command>*",
          "<Arguments>/c *",
          "<Arguments>/k *",
          "<Arguments>/r *",
          "*powershell*",
          "*pwsh*",
          "*mshta*",
          "*wscript*",
          "*cscript*",
          "*certutil*",
          "*bitsadmin*",
          "*bash.exe*",
          "*bash *",
          "*scrcons*",
          "*wmic *",
          "*wmic.exe*",
          "*forfiles*",
          "*scriptrunner*",
          "*hh.exe*"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "*\\AppData\\Local\\Temp\\*",
          "*\\AppData\\Roaming\\*",
          "*\\Users\\Public\\*",
          "*\\WINDOWS\\Temp\\*",
          "C:\\Temp\\*",
          "*\\Desktop\\*",
          "*\\Downloads\\*",
          "*\\Temporary Internet*",
          "C:\\ProgramData\\*",
          "C:\\Perflogs\\*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}