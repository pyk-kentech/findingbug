{
  "name": "Uncommon Service Installation Image Path",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "Service Control Manager",
        "EventID": 7045
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImagePath|contains": [
          " aQBlAHgA",
          " aWV4I",
          " IAB",
          " JAB",
          " PAA",
          " SQBFAFgA",
          " SUVYI"
        ],
        "ImagePath|contains|endswith": [
          " -e"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}