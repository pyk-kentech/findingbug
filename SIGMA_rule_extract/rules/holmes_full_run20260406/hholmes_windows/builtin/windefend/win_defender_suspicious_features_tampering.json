{
  "name": "Windows Defender Configuration Changes",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "5007"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Windows Defender\\DisableAntiSpyware ",
          "\\Windows Defender\\Scan\\DisableRemovableDriveScanning ",
          "\\Windows Defender\\Scan\\DisableScanningMappedNetworkDrivesForFullScan ",
          "\\Windows Defender\\SpyNet\\DisableBlockAtFirstSeen ",
          "\\Real-Time Protection\\SpyNetReporting "
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}