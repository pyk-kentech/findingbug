{
  "name": "Mailbox Export to Exchange Webserver",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "|all|New-MailboxExportRequest",
          "|all|-Mailbox"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "-FilePath \"\\\\*",
          ".aspx"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}