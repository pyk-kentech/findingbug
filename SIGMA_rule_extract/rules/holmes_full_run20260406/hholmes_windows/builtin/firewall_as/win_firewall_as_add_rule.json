    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": [
          "2004",
          "2071",
          "2097"
        ],
        "Action": "2"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "ApplicationPath|startswith": [
          "C:\\Program Files (x86)\\",
          "C:\\Program Files\\",
          "C:\\Windows\\System32\\",
          "C:\\Windows\\SysWOW64\\",
          "C:\\Windows\\WinSxS\\"
        ],
        "ApplicationPath|contains": [
          "C:\\PerfLogs\\",
          "C:\\Temp\\",
          "C:\\Tmp\\",
          "C:\\Users\\Public\\",
          "C:\\Windows\\Tasks\\",
          "C:\\Windows\\Temp\\",
          "\\AppData\\Local\\Temp\\"
        ],
        "ApplicationPath": [
          "System"
        ],
        "ModifyingApplication|startswith": [
          "C:\\Windows\\WinSxS\\",
          "C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\",
          "C:\\Program Files\\Windows Defender\\"
        ],
        "ModifyingApplication|endswith": [
          "\\TiWorker.exe",
          "\\MsMpEng.exe"
        ],
        "ModifyingApplication": [
          "C:\\Windows\\System32\\svchost.exe",
          "C:\\Windows\\System32\\dllhost.exe"
