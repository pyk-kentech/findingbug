{
  "name": "Regsvr32 Execution From Potential Suspicious Location",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\regsvr32.exe"
        ],
        "OriginalFileName": [
          "REGSVR32.EXE"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          ":\\ProgramData\\*",
          ":\\Temp\\*",
          ":\\Users\\Public\\*",
          ":\\Windows\\Temp\\*",
          "\\AppData\\Local\\Temp\\*",
          "\\AppData\\Roaming\\*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}