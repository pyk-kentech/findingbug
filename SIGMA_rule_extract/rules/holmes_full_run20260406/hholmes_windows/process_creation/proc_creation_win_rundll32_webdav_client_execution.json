{
  "name": "WebDav Client Execution Via Rundll32.EXE",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage": "*\\svchost.exe",
        "Image": [
          "*\\rundll32.exe",
          "RUNDLL32.EXE"
        ],
        "CommandLine": "*C:\\windows\\system32\\davclnt.dll,DavSetCookie*"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}