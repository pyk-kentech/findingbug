{
  "name": "Wusa.EXE Executed By Parent Process Located In Suspicious Location",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "\\wusa.exe",
        "ParentImage|contains": [
          ":\\Perflogs\\",
          ":\\Users\\Public\\",
          ":\\Windows\\Temp\\",
          "\\Appdata\\Local\\Temp\\",
          "\\Temporary Internet"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}