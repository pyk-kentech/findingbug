{
  "name": "Loaded Module Enumeration Via Tasklist.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\tasklist.exe",
        "OriginalFileName": "tasklist.exe",
        "CommandLine|contains|windash": "-m"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "*rdpcorets.dll"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}