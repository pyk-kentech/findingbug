{
  "name": "Potential Shim Database Persistence via Sdbinst.EXE",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\sdbinst.exe",
        "OriginalFileName": "sdbinst.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "*\\.sdb"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}