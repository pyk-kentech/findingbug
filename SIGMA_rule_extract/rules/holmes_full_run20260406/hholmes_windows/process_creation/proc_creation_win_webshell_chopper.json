{
  "name": "Chopper Webshell Process Pattern",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\w3wp.exe"
        ],
        "ParentImage|endswith": [
          "\\w3wp.exe"
        ],
        "CommandLine|contains": [
          "&ipconfig&echo",
          "&quser&echo",
          "&whoami&echo",
          "&c:&echo",
          "&cd&echo",
          "&dir&echo",
          "&echo [E]",
          "&echo [S]"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}