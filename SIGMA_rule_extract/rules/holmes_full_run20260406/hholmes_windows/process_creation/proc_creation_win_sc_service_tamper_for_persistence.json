{
  "name": "Potential Persistence Attempt Via Existing Service Tampering",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          "reg ",
          "add ",
          "ImagePath"
        ],
        "CommandLine|contains": [
          ".sh",
          ".exe",
          ".dll",
          ".bin$",
          ".bat",
          ".cmd",
          ".js",
          ".msh$",
          ".reg$",
          ".scr",
          ".ps",
          ".vb",
          ".jar",
          ".pl"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}