{
  "name": "Potentially Suspicious Office Document Executed From Trusted Location",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\explorer.exe",
          "\\dopus.exe"
        ],
        "Image|endswith": [
          "\\EXCEL.EXE",
          "\\POWERPNT.EXE",
          "\\WINWORD.exe"
        ],
        "OriginalFileName": [
          "Excel.exe",
          "POWERPNT.EXE",
          "WinWord.exe"
        ],
        "CommandLine|endswith": [
          ".dotx",
          ".xltx",
          ".potx"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path|contains": [
          "\\AppData\\Roaming\\Microsoft\\Templates",
          "\\AppData\\Roaming\\Microsoft\\Word\\Startup\\",
          "\\Microsoft Office\\root\\Templates\\",
          "\\Microsoft Office\\Templates\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}