{
  "name": "Non-privileged Usage of Reg or Powershell",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*reg add*",
          "*powershell*",
          "*set-itemproperty*",
          "* sp *",
          "*new-itemproperty*"
        ],
        "IntegrityLevel": [
          "Medium",
          "S-1-16-8192"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "*ControlSet*Services*ImagePath*",
          "*ControlSet*Services*FailureCommand*",
          "*ControlSet*Services*ServiceDLL*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}