{
  "name": "HackTool - WSASS Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\wsass.exe",
        "Hashes|contains": "IMPHASH=32F5095C9BBDCACF28FD4060EB4DFC42",
        "CommandLine|re": "(?i)\\.exe[\"']?\\s+[^\"]{0,64}werfaultsecure\\.exe[\"']?\\s+\\d{2,10}"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}