{
  "name": "Suspicious PowerShell Download and Execute Pattern",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "IEX ((New-Object Net.WebClient).DownloadString",
          "IEX (New-Object Net.WebClient).DownloadString",
          "IEX((New-Object Net.WebClient).DownloadString",
          "IEX(New-Object Net.WebClient).DownloadString",
          " -command (New-Object System.Net.WebClient).DownloadFile(",
          " -c (New-Object System.Net.WebClient).DownloadFile("
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}