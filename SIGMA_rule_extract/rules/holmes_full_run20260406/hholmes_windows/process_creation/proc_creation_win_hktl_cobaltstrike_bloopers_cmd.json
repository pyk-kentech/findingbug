{
  "name": "Operator Bloopers Cobalt Strike Commands",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": "Cmd.Exe",
        "Image|endswith": "\\cmd.exe",
        "CommandLine|startswith": [
          "cmd ",
          "cmd.exe",
          "c:\\windows\\system32\\cmd.exe"
        ],
        "CommandLine|contains": [
          "psinject",
          "spawnas",
          "make_token",
          "remote-exec",
          "rev2self",
          "dcsync",
          "logonpasswords",
          "execute-assembly",
          "getsystem"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}