{
  "name": "Suspicious IIS Module Registration",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\w3wp.exe",
        "CommandLine|contains": [
          "appcmd.exe add module",
          "system.enterpriseservices.internal.publish"
        ],
        "Image|endswith": "\\powershell.exe",
        "CommandLine|contains|all": [
          "gacutil",
          " /I"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}