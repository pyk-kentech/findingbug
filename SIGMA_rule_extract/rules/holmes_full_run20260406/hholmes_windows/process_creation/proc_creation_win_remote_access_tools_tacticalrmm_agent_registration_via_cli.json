{
  "name": "Remote Access Tool - TacticalRMM Agent Registration to Potentially Attacker-Controlled Server",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": "\\TacticalAgent\\tacticalrmm.exe",
        "CommandLine|contains|all": [
          "--api",
          "--auth",
          "--client-id",
          "--site-id",
          "--agent-type"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}