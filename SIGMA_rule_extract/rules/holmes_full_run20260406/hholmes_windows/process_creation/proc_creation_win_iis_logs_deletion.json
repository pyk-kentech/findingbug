{
  "name": "IIS WebServer Log Deletion via CommandLine Utilities",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cmd.exe",
          "\\powershell_ise.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "OriginalFileName": [
          "cmd.exe",
          "powershell.exe",
          "powershell_ise.exe",
          "pwsh.dll"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path|contains": [
          "\\inetpub\\logs\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}