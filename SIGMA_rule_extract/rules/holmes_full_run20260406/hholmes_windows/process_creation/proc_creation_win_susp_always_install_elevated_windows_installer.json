{
  "name": "Always Install Elevated Windows Installer",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "User|contains": [
          "AUTHORI",
          "AUTORI"
        ],
        "Image|contains|all": [
          "\\Windows\\Installer\\",
          "msi"
        ],
        "Image|endswith": "tmp",
        "IntegrityLevel": [
          "System",
          "S-1-16-16384"
        ],
        "ParentImage": "C:\\Windows\\System32\\services.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}