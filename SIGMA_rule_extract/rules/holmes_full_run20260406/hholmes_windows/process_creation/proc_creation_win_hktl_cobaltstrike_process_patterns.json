{
  "name": "Potential CobaltStrike Process Patterns",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*cmd.exe /C whoami*",
          "*cmd.exe /c echo* > \\\\.\\pipe*"
        ],
        "ParentImage": [
          "*C:\\Temp\\*",
          "*runonce.exe*",
          "*dllhost.exe*"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}