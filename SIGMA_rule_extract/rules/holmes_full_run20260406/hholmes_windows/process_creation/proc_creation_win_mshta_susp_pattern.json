{
  "name": "Suspicious Mshta.EXE Execution Patterns",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\mshta.exe"
        ],
        "OriginalFileName": "MSHTA.EXE",
        "ParentImage|endswith": [
          "\\cmd.exe",
          "\\cscript.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe",
          "\\wscript.exe"
        ],
        "CommandLine|contains": [
          "\\AppData\\Local\\",
          "C:\\ProgramData\\",
          "C:\\Users\\Public\\",
          "C:\\Windows\\Temp\\",
          ".htm",
          ".hta"
        ],
        "Image|startswith": [
          "C:\\Windows\\System32\\",
          "C:\\Windows\\SysWOW64\\"
        ],
        "CommandLine|endswith": [
          "mshta.exe",
          "mshta"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}