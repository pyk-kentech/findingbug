{
  "name": "Suspicious Service Binary Directory",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          "\\Users\\Public\\",
          "\\\\$Recycle.bin",
          "\\Users\\All Users\\",
          "\\Users\\Default\\",
          "\\Users\\Contacts\\",
          "\\Users\\Searches\\",
          "C:\\Perflogs\\",
          "\\config\\systemprofile\\",
          "\\Windows\\Fonts\\",
          "\\Windows\\IME\\",
          "\\Windows\\addins\\"
        ],
        "ParentImage|endswith": [
          "\\services.exe",
          "\\svchost.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}