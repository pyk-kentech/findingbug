{
  "name": "Console CodePage Lookup Via CHCP",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\cmd.exe",
        "ParentCommandLine|contains|windash": [
          " -c ",
          " -r ",
          " -k "
        ],
        "Image|endswith": "\\chcp.com",
        "CommandLine|endswith": [
          "chcp",
          "chcp ",
          "chcp  "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}