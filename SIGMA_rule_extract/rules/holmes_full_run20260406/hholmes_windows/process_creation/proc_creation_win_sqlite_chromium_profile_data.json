{
  "name": "SQLite Chromium Profile Data DB Access",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\sqlite.exe",
          "\\sqlite3.exe"
        ],
        "CommandLine|contains": [
          "\\User Data\\",
          "\\Opera Software\\",
          "\\ChromiumViewer\\",
          "Login Data",
          "Cookies",
          "Web Data",
          "History",
          "Bookmarks"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}