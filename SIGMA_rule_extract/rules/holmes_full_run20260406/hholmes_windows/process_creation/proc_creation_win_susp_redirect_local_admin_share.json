{
  "name": "Suspicious Redirection to Local Admin Share",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          ">",
          "\\\\127.0.0.1\\admin$\\",
          "\\\\localhost\\admin$\\"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}