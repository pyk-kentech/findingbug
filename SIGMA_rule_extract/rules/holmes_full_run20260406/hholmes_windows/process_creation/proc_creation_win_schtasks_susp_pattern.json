{
  "name": "Suspicious Command Patterns In Scheduled Task Creation",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\schtasks.exe",
        "CommandLine|contains": [
          "/Create ",
          "/sc minute ",
          "/ru system ",
          "cmd /c",
          "cmd /k",
          "cmd /r",
          "cmd.exe /c ",
          "cmd.exe /k ",
          "cmd.exe /r ",
          " -decode ",
          " -enc ",
          " -w hidden ",
          " bypass ",
          " IEX",
          ".DownloadData",
          ".DownloadFile",
          ".DownloadString",
          "/c start /min ",
          "FromBase64String",
          "mshta http",
          "mshta.exe http",
          ":\nProgramData\\",
          ":\nTemp\\",
          ":\nTmp\\",
          ":\nUsers\\Public\\",
          ":\nWindows\\Temp\\",
          "\\AppData\\",
          "%AppData%",
          "%Temp%",
          "%tmp%",
          "cscript",
          "curl",
          "wscript"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}