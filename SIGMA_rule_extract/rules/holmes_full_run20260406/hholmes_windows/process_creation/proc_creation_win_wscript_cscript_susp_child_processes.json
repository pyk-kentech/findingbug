{
  "name": "Cscript/Wscript Potentially Suspicious Child Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\wscript.exe",
          "\\cscript.exe"
        ],
        "Image|endswith": [
          "\\cmd.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "CommandLine|contains|all": [
          "mshta",
          "http"
        ],
        "CommandLine|contains": [
          "rundll32",
          "regsvr32",
          "msiexec"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}