{
  "name": "Findstr Launching .lnk File",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\find.exe",
          "\\findstr.exe"
        ],
        "OriginalFileName": [
          "FIND.EXE",
          "FINDSTR.EXE"
        ],
        "CommandLine|endswith": [
          ".lnk",
          ".lnk\"",
          ".lnk'"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}