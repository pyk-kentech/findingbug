{
  "name": "Potential Privilege Escalation To LOCAL SYSTEM",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "-s cmd",
          "-s -i cmd",
          "-i -s cmd",
          "-s pwsh",
          "-s -i pwsh",
          "-i -s pwsh",
          "-s powershell",
          "-s -i powershell",
          "-i -s powershell"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}