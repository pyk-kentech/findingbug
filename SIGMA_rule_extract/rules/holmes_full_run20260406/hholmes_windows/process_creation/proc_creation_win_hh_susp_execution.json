{
  "name": "Suspicious HH.EXE Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": "HH.exe",
        "Image|endswith": "\\hh.exe",
        "CommandLine|contains": [
          ".application",
          "\\AppData\\Local\\Temp\\",
          "\\Content.Outlook\\",
          "\\Downloads\\",
          "\\Users\\Public\\",
          "\\Windows\\Temp\\"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}