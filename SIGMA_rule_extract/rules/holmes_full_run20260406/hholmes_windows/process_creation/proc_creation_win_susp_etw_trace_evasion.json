    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*cl*|contains|all:*",
          "*clear-log*|contains|all:*",
          "*sl*|contains|all:*",
          "*set-log*|contains|all:*",
          "*logman*update*trace*--p*-ets*|contains|all:*",
          "*Remove-EtwTraceProvider*|contains:*",
          "*Set-EtwTraceProvider*0x11*|contains|all:*"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
