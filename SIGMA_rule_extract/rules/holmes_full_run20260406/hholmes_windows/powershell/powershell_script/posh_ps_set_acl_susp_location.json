{
  "name": "PowerShell Set-Acl On Windows Folder - PsScript",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText": [
          "|contains|all: ['Set-Acl ', '-AclObject ']"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText": [
          "|contains: ['-Path \"C:\\Windows', '-Path \"C:/Windows', \"-Path 'C:\\Windows'",
          "-Path 'C:/Windows'",
          "-Path C:\\Windows",
          "-Path C:/Windows",
          "-Path $env:windir",
          "-Path \"$env:windir",
          "-Path '$env:windir'"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}