{
  "name": "User Discovery And Export Via Get-ADUser Cmdlet - PowerShell",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains|all": [
          "Get-ADUser ",
          " -Filter \\*"
        ],
        "ScriptBlockText|contains": [
          " > ",
          " | Select ",
          "Out-File",
          "Set-Content",
          "Add-Content"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}