{
  "name": "Usage Of Web Request Commands And Cmdlets - ScriptBlock",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "[System.Net.WebRequest]::create",
          "curl ",
          "Invoke-RestMethod",
          "Invoke-WebRequest",
          " irm ",
          "iwr ",
          "Resume-BitsTransfer",
          "Start-BitsTransfer",
          "wget ",
          "WinHttp.WinHttpRequest"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}