{
  "name": "Automated Collection Command PowerShell",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": "*Get-ChildItem*"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "*.doc|*.docx|*.xls|*.xlsx|*.ppt|*.pptx|*.rtf|*.pdf|*.txt"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}