{
  "name": "Potential Persistence Via Security Descriptors - ScriptBlock",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains|all": [
          "win32_Trustee",
          "win32_Ace",
          ".AccessMask",
          ".AceType",
          ".SetSecurityDescriptor"
        ],
        "ScriptBlockText|contains": [
          "\\Lsa\\JD",
          "\\Lsa\\Skew1",
          "\\Lsa\\Data",
          "\\Lsa\\GBG"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}