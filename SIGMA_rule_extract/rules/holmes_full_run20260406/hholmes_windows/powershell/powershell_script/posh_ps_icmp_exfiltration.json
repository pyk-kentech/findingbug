{
  "name": "PowerShell ICMP Exfiltration",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains|all": [
          "New-Object",
          "System.Net.NetworkInformation.Ping",
          ".Send("
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}