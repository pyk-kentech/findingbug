{
  "name": "Suspicious PowerShell Invocations - Specific",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*-nop*",
          "*-w hidden*",
          "*-c [Convert]::FromBase64String*",
          "*-noni -nop -c iex New-Object*",
          "*-ep bypass -Enc*",
          "*powershell reg add*",
          "*bypass -noprofile -windowstyle hidden new-object system.net.webclient .download*",
          "*iex New-Object Net.WebClient .Download*"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename": [
          "*\reg*",
          "*\run*",
          "*\run*",
          "*\run*"
        ],
        "file_path": [
          "*https://community.chocolatey.org/install.ps1*",
          "*https://chocolatey.org/install.ps1*",
          "*Write-ChocolateyWarning*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}