{
  "name": "WerFault LSASS Process Memory Dump",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "C:\\WINDOWS\\system32\\WerFault.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\lsass",
          "lsass.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}