{
  "name": "Publisher Attachment File Dropped In Suspicious Location",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename": [
          "*\\AppData\\Local\\Temp\\*",
          "*\\Users\\Public\\*",
          "*\\Windows\\Temp\\*",
          "C:\\Temp\\*"
        ],
        "TargetFilename|endswith": ".pub"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}