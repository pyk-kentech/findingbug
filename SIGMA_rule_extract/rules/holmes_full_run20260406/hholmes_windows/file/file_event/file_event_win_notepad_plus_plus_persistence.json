{
  "name": "Potential Persistence Via Notepad++ Plugins",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": ".exe",
        "Image|startswith": "C:\\Users\\",
        "Image|contains": "\\npp."
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\Notepad++\\plugins\\",
        "TargetFilename|endswith": ".dll",
        "TargetFilename": [
          "C:\\Program Files\\Notepad++\\plugins\\NppExport\\NppExport.dll",
          "C:\\Program Files\\Notepad++\\plugins\\mimeTools\\mimeTools.dll",
          "C:\\Program Files\\Notepad++\\plugins\\NppConverter\\NppConverter.dll",
          "C:\\Program Files\\Notepad++\\plugins\\Config\\nppPluginList.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}