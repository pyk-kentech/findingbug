{
  "name": "File With Uncommon Extension Created By An Office Application",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\excel.exe",
          "\\msaccess.exe",
          "\\mspub.exe",
          "\\powerpnt.exe",
          "\\visio.exe",
          "\\winword.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".bat",
          ".cmd",
          ".com",
          ".dll",
          ".exe",
          ".hta",
          ".ocx",
          ".proj",
          ".ps1",
          ".scf",
          ".scr",
          ".sys",
          ".vbe",
          ".vbs",
          ".wsf",
          ".wsh"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}