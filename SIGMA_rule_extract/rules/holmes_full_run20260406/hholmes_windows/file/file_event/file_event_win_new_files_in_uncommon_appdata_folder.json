{
  "name": "Suspicious File Creation In Uncommon AppData Folder",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|startswith": [
          "C:\\Users\\"
        ],
        "TargetFilename|contains": [
          "\\AppData\\"
        ],
        "TargetFilename|endswith": [
          ".bat",
          ".cmd",
          ".cpl",
          ".dll",
          ".exe",
          ".hta",
          ".iso",
          ".lnk",
          ".msi",
          ".ps1",
          ".psm1",
          ".scr",
          ".vbe",
          ".vbs"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}