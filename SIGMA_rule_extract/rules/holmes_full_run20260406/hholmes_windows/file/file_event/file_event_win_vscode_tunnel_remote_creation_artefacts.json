{
  "name": "Visual Studio Code Tunnel Remote File Creation",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": [
          "\\servers\\Stable-*",
          "\\server\\node.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename": [
          "\\.vscode-server\\data\\User\\History\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}