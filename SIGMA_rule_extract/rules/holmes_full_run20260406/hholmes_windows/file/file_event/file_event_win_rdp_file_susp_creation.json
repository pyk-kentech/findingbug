{
  "name": ".RDP File Created By Uncommon Application",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\brave.exe",
          "\\CCleaner Browser\\Application\\CCleanerBrowser.exe",
          "\\chromium.exe",
          "\\firefox.exe",
          "\\Google\\Chrome\\Application\\chrome.exe",
          "\\iexplore.exe",
          "\\microsoftedge.exe",
          "\\msedge.exe",
          "\\Opera.exe",
          "\\Vivaldi.exe",
          "\\Whale.exe",
          "\\olk.exe",
          "\\Outlook.exe",
          "\\RuntimeBroker.exe",
          "\\Thunderbird.exe",
          "\\Discord.exe",
          "\\Keybase.exe",
          "\\msteams.exe",
          "\\Slack.exe",
          "\\teams.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": ".rdp"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}