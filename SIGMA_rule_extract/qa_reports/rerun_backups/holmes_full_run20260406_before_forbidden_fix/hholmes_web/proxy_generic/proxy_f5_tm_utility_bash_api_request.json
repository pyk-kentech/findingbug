{
  "name": "F5 BIG-IP iControl Rest API Command Execution - Proxy",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "cs-method": "POST"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "c-uri|endswith": "/mgmt/tm/util/bash"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}