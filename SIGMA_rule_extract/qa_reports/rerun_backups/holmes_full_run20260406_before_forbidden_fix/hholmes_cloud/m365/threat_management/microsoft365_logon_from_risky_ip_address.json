{
  "name": "Logon from a Risky IP Address",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventSource": "SecurityComplianceCenter",
        "eventName": "Log on from a risky IP address",
        "status": "success"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}