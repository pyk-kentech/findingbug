{
  "name": "LSASS Memory Access by Tool With Dump Keyword In Name",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {
        "SourceImage|contains": "dump"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetImage|endswith": "\\lsass.exe"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}