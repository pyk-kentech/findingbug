{
  "name": "Suspicious Process Access of MsMpEng by WerFaultSecure - EDR-Freeze",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "SourceImage|endswith": "\\WerFaultSecure.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetImage|endswith": "\\MsMpEng.exe",
        "CallTrace|contains": [
          "\\dbgcore.dll",
          "\\dbghelp.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}