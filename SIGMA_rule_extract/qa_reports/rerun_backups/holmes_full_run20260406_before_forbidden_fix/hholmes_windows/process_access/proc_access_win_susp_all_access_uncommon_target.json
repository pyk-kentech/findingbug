{
  "name": "Uncommon Process Access Rights For Target Image",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "GrantedAccess": "0x1FFFFF"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetImage|endswith": [
          "\\calc.exe",
          "\\calculator.exe",
          "\\mspaint.exe",
          "\\notepad.exe",
          "\\ping.exe",
          "\\wordpad.exe",
          "\\write.exe"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}