{
  "name": "New ODBC Driver Registered",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\SOFTWARE\\ODBC\\ODBCINST.INI\\",
          "\\Driver"
        ],
        "Details|startswith": [
          "%WINDIR%\\System32\\SQLSRV32.dll",
          "C:\\Progra"
        ],
        "Details|endswith": [
          "\\ACEODBC.DLL"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}