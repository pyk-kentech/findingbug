{
  "name": "Potentially Suspicious Command Executed Via Run Dialog Box - Registry",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\Microsoft\\Windows\\CurrentVersion\\Explorer\\RunMRU",
        "Details|contains": [
          "powershell",
          "pwsh",
          " -e ",
          " -ec ",
          " -en ",
          " -enc ",
          " -enco",
          "ftp",
          "Hidden",
          "http",
          "iex",
          "Invoke-",
          "wmic",
          "shadowcopy",
          "process call create"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}