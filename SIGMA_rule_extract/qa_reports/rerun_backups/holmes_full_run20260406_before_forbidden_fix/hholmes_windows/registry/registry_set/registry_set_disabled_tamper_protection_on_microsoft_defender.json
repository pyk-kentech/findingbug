{
  "name": "Disable Tamper Protection on Windows Defender",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": "C:\\ProgramData\\Microsoft\\Windows Defender\\Platform\\",
        "Image|endswith": "\\MsMpEng.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\Microsoft\\Windows Defender\\Features\\TamperProtection",
        "Details": "DWORD (0x00000000)"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}