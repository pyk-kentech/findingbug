{
  "name": "Modification of IE Registry Settings",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Software\\Microsoft\\Windows\\CurrentVersion\\Internet Settings",
          "\\Cache",
          "\\ZoneMap",
          "\\WpadDecision"
        ],
        "Details|startswith": "DWORD",
        "Details": [
          null,
          "Cookie:",
          "Visited:",
          "(Empty)",
          "Binary Data"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}