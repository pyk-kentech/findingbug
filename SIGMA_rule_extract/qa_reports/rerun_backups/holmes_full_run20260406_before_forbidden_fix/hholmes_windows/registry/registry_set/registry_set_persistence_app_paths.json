{
  "name": "Potential Persistence Via App Paths Default Property",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\App Paths",
        "TargetObject|endswith": [
          "(Default)",
          "Path"
        ],
        "Details|contains": [
          "\\Users\\Public",
          "\\AppData\\Local\\Temp\\",
          "\\Windows\\Temp\\",
          "\\Desktop\\",
          "\\Downloads\\",
          "%temp%",
          "%tmp%",
          "iex",
          "Invoke-",
          "rundll32",
          "regsvr32",
          "mshta",
          "cscript",
          "wscript",
          ".bat",
          ".hta",
          ".dll",
          ".ps1"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}