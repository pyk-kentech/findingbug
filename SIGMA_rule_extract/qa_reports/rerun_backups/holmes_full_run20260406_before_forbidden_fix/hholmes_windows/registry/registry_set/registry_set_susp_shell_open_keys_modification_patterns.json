{
  "name": "Suspicious Shell Open Command Registry Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": "\\shell\\open\\command\\",
        "Details|contains": [
          "\\\\Recycle.Bin\\\\",
          "\\\\AppData\\\\Local\\\\Temp\\\\",
          "\\\\Contacts\\\\",
          "\\\\Music\\\\",
          "\\\\PerfLogs\\\\",
          "\\\\Photos\\\\",
          "\\\\Pictures\\\\",
          "\\\\Users\\\\Public\\\\",
          "\\\\Videos\\\\",
          "\\\\Windows\\\\Temp\\\\",
          "%AppData%",
          "%LocalAppData%",
          "%Temp%",
          "%tmp%"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}