{
  "name": "RDP Sensitive Settings Changed",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|contains": [
          "\\Control\\Terminal Server\\",
          "\\Windows NT\\Terminal Services\\"
        ],
        "TargetObject|endswith": [
          "\\Shadow",
          "\\DisableRemoteDesktopAntiAlias",
          "\\DisableSecuritySettings",
          "\\fAllowUnsolicited",
          "\\fAllowUnsolicitedFullControl",
          "\\InitialProgram",
          "\\WinStations\\RDP-Tcp\\InitialProgram",
          "\\services\\TermService\\Parameters\\ServiceDll",
          "\\Terminal Server\\WinStations\\RDP-Tcp\\SecurityLayer"
        ],
        "Details": [
          "DWORD (0x00000001)",
          "DWORD (0x00000002)",
          "DWORD (0x00000003)",
          "DWORD (0x00000004)"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}