{
  "name": "Shell Open Registry Keys Manipulation",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject|endswith": [
          "Classes\\ms-settings\\shell\\open\\command\\SymbolicLinkValue",
          "Classes\\ms-settings\\shell\\open\\command\\DelegateExecute",
          "Classes\\ms-settings\\shell\\open\\command\\(Default)",
          "Classes\\exefile\\shell\\open\\command\\(Default)"
        ],
        "Details|contains": "\\Software\\Classes\\{"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}