{
  "name": "Modify Group Policy Settings - ScriptBlockLogging",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ScriptBlockText|contains": [
          "\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
          "GroupPolicyRefreshTimeDC",
          "GroupPolicyRefreshTimeOffsetDC",
          "GroupPolicyRefreshTime",
          "GroupPolicyRefreshTimeOffset",
          "EnableSmartScreen",
          "ShellSmartScreenLevel"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}