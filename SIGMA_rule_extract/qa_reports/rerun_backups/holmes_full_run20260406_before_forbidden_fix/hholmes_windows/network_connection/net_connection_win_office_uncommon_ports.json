{
  "name": "Office Application Initiated Network Connection Over Uncommon Ports",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\excel.exe",
          "\\outlook.exe",
          "\\powerpnt.exe",
          "\\winword.exe",
          "\\wordview.exe"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationPort": [
          53,
          80,
          139,
          389,
          443,
          445,
          3268
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}