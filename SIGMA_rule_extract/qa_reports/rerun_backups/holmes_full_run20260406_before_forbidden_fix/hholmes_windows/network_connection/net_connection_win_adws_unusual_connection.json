{
  "name": "Uncommon Connection to Active Directory Web Services",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|startswith": [
          "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
          "C:\\Program Files\\PowerShell\\7-preview\\pwsh.ex",
          "C:\\Windows\\System32\\WindowsPowerShell\\",
          "C:\\Windows\\SysWOW64\\WindowsPowerShell\\"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationPort": 9389
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}