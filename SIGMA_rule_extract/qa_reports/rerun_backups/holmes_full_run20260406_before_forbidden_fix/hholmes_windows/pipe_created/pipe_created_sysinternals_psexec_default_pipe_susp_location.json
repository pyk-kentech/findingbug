{
  "name": "PsExec Tool Execution From Suspicious Locations - PipeName",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          ":\\Users\\Public\\",
          ":\\Windows\\Temp\\",
          "\\AppData\\Local\\Temp\\",
          "\\Desktop\\",
          "\\Downloads\\"
        ]
      }
    },
    "object": {
      "type": "NamedPipe",
      "attributes": {
        "PipeName": "\\PSEXESVC"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}