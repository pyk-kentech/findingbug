      "attributes": {
        "TaskContentNew|contains": [
          "\\AppData\\Local\\Temp\\",
          "\\AppData\\Roaming\\",
          "\\Users\\Public\\",
          "\\WINDOWS\\Temp\\",
          "C:\\Temp\\",
          "\\Desktop\\",
          "\\Downloads\\",
          "\\Temporary Internet",
          "C:\\ProgramData\\",
          "C:\\Perflogs\\"
        ]
      }
    },
    "entity_bindings": {
