{
  "name": "Remote Service Activity via SVCCTL Named Pipe",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "AccessList": "WriteData"
      }
    },
    "object": {
      "type": "Identity",
      "attributes": {
        "ShareName": "\\\\\\\\\\*\\\\IPC$",
        "RelativeTargetName": "svcctl"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}