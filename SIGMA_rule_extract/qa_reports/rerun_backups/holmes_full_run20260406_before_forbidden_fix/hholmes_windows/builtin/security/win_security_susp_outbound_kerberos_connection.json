{
  "name": "Uncommon Outbound Kerberos Connection - Security",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "Application|startswith": [
          "\\device\\harddiskvolume",
          "C:"
        ],
        "Application|endswith": [
          "\\Windows\\System32\\lsass.exe",
          "\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe",
          "\\Program Files\\Google\\Chrome\\Application\\chrome.exe",
          "\\Program Files (x86)\\Mozilla Firefox\\firefox.exe",
          "\\Program Files\\Mozilla Firefox\\firefox.exe",
          "\\tomcat\\bin\\tomcat8.exe"
        ]
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationPort": 88
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}