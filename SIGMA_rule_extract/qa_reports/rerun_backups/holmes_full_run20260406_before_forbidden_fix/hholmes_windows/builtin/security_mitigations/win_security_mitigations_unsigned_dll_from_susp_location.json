{
  "name": "Unsigned Binary Loaded From Suspicious Location",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ImageName|contains": [
          "\\Users\\Public\\",
          "\\PerfLogs\\",
          "\\Desktop\\",
          "\\Downloads\\",
          "\\AppData\\Local\\Temp\\",
          "C:\\Windows\\TEMP\\"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}