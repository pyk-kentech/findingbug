{
  "name": "BITS Transfer Job With Uncommon Or Suspicious Remote TLD",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {
        "EventID": "16403"
      }
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "RemoteName|contains": [
          ".azureedge.net/",
          ".com/",
          ".sfx.ms/",
          "download.mozilla.org/",
          "cdn.onenote.net/",
          "cdn.office.net/",
          "tscdn.m365.static.microsoft/"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}