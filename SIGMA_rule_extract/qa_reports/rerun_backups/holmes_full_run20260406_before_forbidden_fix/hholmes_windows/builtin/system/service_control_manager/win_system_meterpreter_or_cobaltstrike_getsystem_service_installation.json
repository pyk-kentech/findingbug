{
  "name": "Meterpreter or Cobalt Strike Getsystem Service Installation - System",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "ImagePath|contains|all": [
          "/c",
          "echo",
          "\\pipe\\"
        ],
        "ImagePath|contains": [
          "cmd",
          "%COMSPEC%"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}