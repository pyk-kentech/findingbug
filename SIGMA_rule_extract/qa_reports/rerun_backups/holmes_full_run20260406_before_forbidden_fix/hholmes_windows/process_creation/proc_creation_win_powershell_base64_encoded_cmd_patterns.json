{
  "name": "Suspicious PowerShell Encoded Command Patterns",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "OriginalFileName": [
          "PowerShell.Exe",
          "pwsh.dll"
        ],
        "CommandLine|contains": [
          " -e ",
          " -en ",
          " -enc ",
          " -enco",
          " JAB",
          " SUVYI",
          " SQBFAFgA",
          " aWV4I",
          " IAB",
          " PAA",
          " aQBlAHgA"
        ],
        "ParentImage|contains": [
          "C:\\Packages\\Plugins\\Microsoft.GuestConfiguration.ConfigurationforWindows\\",
          "\\gc_worker.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}