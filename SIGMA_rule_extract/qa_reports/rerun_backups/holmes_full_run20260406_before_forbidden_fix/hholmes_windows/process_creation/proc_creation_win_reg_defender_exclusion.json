{
  "name": "Suspicious Windows Defender Folder Exclusion Added Via Reg.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\reg.exe",
        "CommandLine|contains": [
          "SOFTWARE\\Microsoft\\Windows Defender\\Exclusions\\Paths",
          "SOFTWARE\\Microsoft\\Microsoft Antimalware\\Exclusions\\Paths"
        ],
        "CommandLine|contains|all": [
          "ADD ",
          "/t ",
          "REG_DWORD ",
          "/v ",
          "/d ",
          "0"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}