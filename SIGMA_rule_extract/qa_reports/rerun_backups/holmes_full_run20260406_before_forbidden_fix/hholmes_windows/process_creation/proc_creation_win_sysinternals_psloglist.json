{
  "name": "Suspicious Use of PsLogList",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": "psloglist.exe",
        "Image|endswith": [
          "\\psloglist.exe",
          "\\psloglist64.exe"
        ],
        "CommandLine|contains": [
          " security",
          " application",
          " system",
          " -d",
          " -x",
          " -s",
          " -c",
          " -g"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}