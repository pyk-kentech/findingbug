{
  "name": "Suspicious WMIC Execution Via Office Process",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\WINWORD.EXE",
          "\\EXCEL.EXE",
          "\\POWERPNT.exe",
          "\\MSPUB.exe",
          "\\VISIO.exe",
          "\\MSACCESS.EXE",
          "\\EQNEDT32.EXE",
          "\\ONENOTE.EXE",
          "\\wordpad.exe",
          "\\wordview.exe"
        ],
        "Image|endswith": "\\wbem\\WMIC.exe",
        "OriginalFileName": "wmic.exe",
        "CommandLine|contains|all": [
          "process",
          "create",
          "call"
        ],
        "CommandLine|contains": [
          "regsvr32",
          "rundll32",
          "msiexec",
          "mshta",
          "verclsid",
          "wscript",
          "cscript"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}