{
  "name": "File Download Via Bitsadmin To A Suspicious Target Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\bitsadmin.exe",
        "OriginalFileName": "bitsadmin.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          ":\\Perflogs",
          ":\\ProgramData\\",
          ":\\Temp\\",
          ":\\Users\\Public\\",
          ":\\Windows\\",
          "\\\\$Recycle.Bin\\",
          "\\AppData\\Local\\",
          "\\AppData\\Roaming\\",
          "\\Contacts\\",
          "\\Desktop\\",
          "\\Favorites\\",
          "\\Favourites\\",
          "\\inetpub\\wwwroot\\",
          "\\Music\\",
          "\\Pictures\\",
          "\\Start Menu\\Programs\\Startup\\",
          "\\Users\\Default\\",
          "\\Videos\\",
          "%ProgramData%",
          "%public%",
          "%temp%",
          "%tmp%"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}