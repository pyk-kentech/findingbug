{
  "name": "Suspicious Windows Defender Registry Key Tampering Via Reg.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\reg.exe",
        "OriginalFileName": "reg.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject": [
          "SOFTWARE\\Microsoft\\Windows Defender\\*",
          "SOFTWARE\\Policies\\Microsoft\\Windows Defender Security Center\\*",
          "SOFTWARE\\Policies\\Microsoft\\Windows Defender\\*"
        ],
        "Details": [
          "DisallowExploitProtectionOverride",
          "EnableControlledFolderAccess",
          "MpEnablePus",
          "PUAProtection",
          "SpynetReporting",
          "SubmitSamplesConsent",
          "TamperProtection",
          "DisableAccess",
          "DisableAntiSpyware",
          "DisableAntiSpywareRealtimeProtection",
          "DisableAntiVirus",
          "DisableAntiVirusSignatures",
          "DisableArchiveScanning",
          "DisableBehaviorMonitoring",
          "DisableBlockAtFirstSeen",
          "DisableCloudProtection",
          "DisableConfig",
          "DisableEnhancedNotifications",
          "DisableIntrusionPreventionSystem",
          "DisableIOAVProtection",
          "DisableNetworkProtection",
          "DisableOnAccessProtection",
          "DisablePrivacyMode",
          "DisableRealtimeMonitoring",
          "DisableRoutinelyTakingAction",
          "DisableScanOnRealtimeEnable",
          "DisableScriptScanning",
          "DisableSecurityCenter",
          "Notification_Suppress",
          "SignatureDisableUpdateOnStartupWithoutEngine"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}