          "kAbgB2AG8AawBlAC0A",
          "JAG4AdgBvAGsAZQAtA",
          "SW52b2tlL",
          "ludm9rZS",
          "JbnZva2Ut"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
