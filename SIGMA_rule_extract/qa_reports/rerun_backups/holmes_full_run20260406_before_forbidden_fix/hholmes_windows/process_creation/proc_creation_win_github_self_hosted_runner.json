{
  "name": "Github Self-Hosted Runner Execution",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\Runner.Worker.exe",
          "\\Runner.Listener.exe"
        ],
        "OriginalFileName": [
          "Runner.Worker.dll",
          "Runner.Listener.dll"
        ],
        "CommandLine|contains": [
          "spawnclient",
          "run",
          "configure"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}