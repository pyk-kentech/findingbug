{
  "name": "Security Event Logging Disabled via MiniNt Registry Key - Process",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          " add ",
          "\\SYSTEM\\CurrentControlSet\\Control\\MiniNt"
        ],
        "Image|endswith": "\\reg.exe",
        "OriginalFileName": "reg.exe"
      }
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject": "HKEY_LOCAL_MACHINE\\SYSTEM\\CurrentControlSet\\Control\\MiniNt"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}