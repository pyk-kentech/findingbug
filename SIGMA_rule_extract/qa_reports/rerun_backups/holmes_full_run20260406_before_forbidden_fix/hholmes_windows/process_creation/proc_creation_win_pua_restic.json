{
  "name": "PUA - Restic Backup Tool Execution",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains|all": [
          " init ",
          " -r "
        ],
        "CommandLine|contains": [
          "sftp:",
          "rest:http",
          "s3:s3.",
          "s3.http",
          "azure:",
          " gs:",
          "rclone:",
          "swift:",
          " b2:"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}