{
  "name": "Suspicious Process Start Locations",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          ":\\"
        ],
        "Image|startswith": [
          "C:\\Windows\\Tasks\\",
          "C:\\Windows\\debug\\",
          "C:\\Windows\\fonts\\",
          "C:\\Windows\\help\\",
          "C:\\Windows\\drivers\\",
          "C:\\Windows\\addins\\",
          "C:\\Windows\\cursors\\",
          "C:\\Windows\\system32\\tasks\\"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}