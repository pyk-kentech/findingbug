{
  "name": "Suspicious WebDav Client Execution Via Rundll32.EXE",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": "\\svchost.exe",
        "ParentCommandLine|contains": "-s WebClient",
        "Image|endswith": "\\rundll32.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": "C:\\windows\\system32\\davclnt.dll,DavSetCookie"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}