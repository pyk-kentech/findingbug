{
  "name": "Suspicious Download From File-Sharing Website Via Bitsadmin",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\bitsadmin.exe",
        "OriginalFileName": "bitsadmin.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          ".githubusercontent.com",
          "anonfiles.com",
          "cdn.discordapp.com",
          "ddns.net",
          "dl.dropboxusercontent.com",
          "ghostbin.co",
          "github.com",
          "glitch.me",
          "gofile.io",
          "hastebin.com",
          "mediafire.com",
          "mega.nz",
          "onrender.com",
          "pages.dev",
          "paste.ee",
          "pastebin.com",
          "pastebin.pl",
          "pastetext.net",
          "privatlab.com",
          "privatlab.net",
          "send.exploit.in",
          "sendspace.com",
          "storage.googleapis.com",
          "storjshare.io",
          "supabase.co",
          "temp.sh",
          "transfer.sh",
          "trycloudflare.com",
          "ufile.io",
          "w3spaces.com",
          "workers.dev"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}