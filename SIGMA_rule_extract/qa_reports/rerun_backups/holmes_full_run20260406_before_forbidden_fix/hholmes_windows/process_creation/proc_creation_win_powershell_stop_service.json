{
  "name": "Stop Windows Service Via PowerShell Stop-Service",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": [
          "PowerShell.EXE",
          "pwsh.dll"
        ],
        "Image|endswith": [
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "CommandLine|contains": "Stop-Service "
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}