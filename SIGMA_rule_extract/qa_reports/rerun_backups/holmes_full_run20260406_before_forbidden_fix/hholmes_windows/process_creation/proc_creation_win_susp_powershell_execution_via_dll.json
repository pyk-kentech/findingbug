{
  "name": "Potential PowerShell Execution Via DLL",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\InstallUtil.exe",
          "\\RegAsm.exe",
          "\\RegSvcs.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe"
        ],
        "OriginalFileName": [
          "InstallUtil.exe",
          "RegAsm.exe",
          "RegSvcs.exe",
          "REGSVR32.EXE",
          "RUNDLL32.EXE"
        ],
        "CommandLine|contains": [
          "Default.GetString",
          "DownloadString",
          "FromBase64String",
          "ICM ",
          "IEX ",
          "Invoke-Command",
          "Invoke-Expression"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}