{
  "name": "File Encryption/Decryption Via Gpg4win From Suspicious Locations",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\gpg.exe",
          "\\gpg2.exe"
        ],
        "Product": "GNU Privacy Guard (GnuPG)",
        "Description": "GnuPG’s OpenPGP tool",
        "CommandLine|contains": "-passphrase"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          ":\\PerfLogs\\",
          ":\\Temp\\",
          ":\\Users\\Public\\",
          ":\\Windows\\Temp\\",
          "\\AppData\\Local\\Temp\\",
          "\\AppData\\Roaming\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}