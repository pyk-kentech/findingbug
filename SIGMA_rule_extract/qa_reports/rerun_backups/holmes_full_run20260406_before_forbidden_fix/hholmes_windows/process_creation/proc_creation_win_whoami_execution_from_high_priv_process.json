{
  "name": "Whoami.EXE Execution From Privileged Process",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": "whoami.exe",
        "Image|endswith": "\\whoami.exe",
        "User|contains": [
          "AUTHORI",
          "TrustedInstaller"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}