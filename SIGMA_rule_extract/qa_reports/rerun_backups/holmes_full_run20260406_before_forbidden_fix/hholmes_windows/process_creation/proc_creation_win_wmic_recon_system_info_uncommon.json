{
  "name": "Uncommon System Information Discovery Via Wmic.EXE",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Description": "WMI Commandline Utility",
        "OriginalFileName": "wmic.exe",
        "Image|endswith": "\\WMIC.exe"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "LOGICALDISK get Name,Size,FreeSpace",
          "os get Caption,OSArchitecture,Version"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}