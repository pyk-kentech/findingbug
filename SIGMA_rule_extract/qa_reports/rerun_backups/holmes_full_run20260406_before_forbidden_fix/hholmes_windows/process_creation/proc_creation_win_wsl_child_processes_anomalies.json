{
  "name": "WSL Child Process Anomaly",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\wsl.exe",
          "\\wslhost.exe"
        ]
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\calc.exe",
          "\\cmd.exe",
          "\\cscript.exe",
          "\\mshta.exe",
          "\\powershell.exe",
          "\\pwsh.exe",
          "\\regsvr32.exe",
          "\\rundll32.exe",
          "\\wscript.exe"
        ],
        "Image|contains": [
          "\\AppData\\Local\\Temp\\",
          "C:\\Users\\Public\\",
          "C:\\Windows\\Temp\\",
          "C:\\Temp\\",
          "\\Downloads\\",
          "\\Desktop\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}