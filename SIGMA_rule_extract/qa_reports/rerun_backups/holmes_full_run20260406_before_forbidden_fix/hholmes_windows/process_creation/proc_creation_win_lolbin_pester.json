{
  "name": "Execute Code with Pester.bat as Parent",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|endswith": [
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "ParentCommandLine|contains": [
          "\\WindowsPowerShell\\Modules\\Pester\\",
          "{ Invoke-Pester -EnableExit ;",
          "{ Get-Help \""
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}