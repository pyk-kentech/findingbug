{
  "name": "Always Install Elevated MSI Spawned Cmd And Powershell",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "SPAWN",
    "subject": {
      "type": "Process",
      "attributes": {
        "ParentImage|contains|all": [
          "\\Windows\\Installer\\",
          "msi"
        ],
        "ParentImage|endswith": "tmp"
      }
    },
    "object": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\cmd.exe",
          "\\powershell.exe",
          "\\pwsh.exe"
        ],
        "OriginalFileName": [
          "Cmd.Exe",
          "PowerShell.EXE",
          "pwsh.dll"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}