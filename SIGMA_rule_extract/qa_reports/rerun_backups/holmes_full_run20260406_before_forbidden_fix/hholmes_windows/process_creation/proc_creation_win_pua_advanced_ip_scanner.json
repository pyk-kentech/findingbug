{
  "name": "PUA - Advanced IP Scanner Execution",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          "\\advanced_ip_scanner"
        ],
        "OriginalFileName|contains": [
          "advanced_ip_scanner"
        ],
        "Description|contains": [
          "Advanced IP Scanner"
        ],
        "CommandLine|contains|all": [
          "/portable",
          "/lng"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}