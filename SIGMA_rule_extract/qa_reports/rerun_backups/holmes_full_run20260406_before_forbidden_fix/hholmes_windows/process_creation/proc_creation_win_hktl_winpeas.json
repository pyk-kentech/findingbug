{
  "name": "HackTool - winPEAS Execution",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "OriginalFileName": "winPEAS.exe",
        "Image|endswith": [
          "\\winPEASany_ofs.exe",
          "\\winPEASany.exe",
          "\\winPEASx64_ofs.exe",
          "\\winPEASx64.exe",
          "\\winPEASx86_ofs.exe",
          "\\winPEASx86.exe"
        ],
        "CommandLine|contains": [
          " applicationsinfo",
          " browserinfo",
          " eventsinfo",
          " fileanalysis",
          " filesinfo",
          " processinfo",
          " servicesinfo",
          " windowscreds"
        ],
        "ParentCommandLine|endswith": " -linpeas",
        "CommandLine|endswith": " -linpeas"
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}