{
  "name": "Suspicious Download from Office Domain",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\curl.exe",
          "\\wget.exe"
        ],
        "CommandLine|contains": [
          "Invoke-WebRequest",
          "iwr ",
          "curl ",
          "wget ",
          "Start-BitsTransfer",
          ".DownloadFile(",
          ".DownloadString("
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": []
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}