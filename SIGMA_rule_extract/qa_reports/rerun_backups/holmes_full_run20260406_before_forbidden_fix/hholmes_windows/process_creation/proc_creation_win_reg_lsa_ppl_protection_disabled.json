    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject": "SYSTEM\\CurrentControlSet\\Control\\Lsa",
        "Details": "RunAsPPL"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}