{
  "name": "Copying Sensitive Files with Credential Data",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\esentutl.exe",
        "OriginalFileName": "\\esentutl.exe",
        "CommandLine|contains|windash": [
          "vss",
          " /m ",
          " /y "
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "\\config\\RegBack\\sam",
          "\\config\\RegBack\\security",
          "\\config\\RegBack\\system",
          "\\config\\sam",
          "\\config\\security",
          "\\config\\system ",
          "\\repair\\sam",
          "\\repair\\security",
          "\\repair\\system",
          "\\windows\\ntds\\ntds.dit"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}