{
  "name": "Set Suspicious Files as System Files Using Attrib.EXE",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\attrib.exe",
        "OriginalFileName": "ATTRIB.EXE",
        "CommandLine|contains": [
          " +s",
          " %",
          "\\Users\\Public\\",
          "\\AppData\\Local\\",
          "\\ProgramData\\",
          "\\Downloads\\",
          "\\Windows\\Temp\\",
          ".bat",
          ".dll",
          ".exe",
          ".hta",
          ".ps1",
          ".vbe",
          ".vbs"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}