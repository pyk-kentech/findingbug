{
  "name": "Suspicious Debugger Registration Cmdline",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine|contains": [
          "\\CurrentVersion\\Image File Execution Options\\",
          "sethc.exe",
          "utilman.exe",
          "osk.exe",
          "magnify.exe",
          "narrator.exe",
          "displayswitch.exe",
          "atbroker.exe",
          "HelpPane.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}