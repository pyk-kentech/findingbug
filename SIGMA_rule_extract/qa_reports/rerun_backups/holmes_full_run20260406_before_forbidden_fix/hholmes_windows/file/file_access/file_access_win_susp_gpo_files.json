{
  "name": "Access To Potentially Sensitive Sysvol Files By Uncommon Applications",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|startswith": "\\\\",
        "TargetFilename|contains|all": [
          "\\sysvol\\",
          "\\Policies\\"
        ],
        "TargetFilename|endswith": [
          "audit.csv",
          "Files.xml",
          "GptTmpl.inf",
          "groups.xml",
          "Registry.pol",
          "Registry.xml",
          "scheduledtasks.xml",
          "scripts.ini",
          "services.xml"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}