{
  "name": "Suspicious PROCEXP152.sys File Created In TMP",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": [
          "\\procexp64.exe",
          "\\procexp.exe",
          "\\procmon64.exe",
          "\\procmon.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\AppData\\Local\\Temp\\",
        "TargetFilename|endswith": "PROCEXP152.sys"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}