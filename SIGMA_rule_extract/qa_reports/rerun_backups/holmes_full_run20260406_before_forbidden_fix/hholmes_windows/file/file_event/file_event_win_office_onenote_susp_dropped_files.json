{
  "name": "Suspicious File Created Via OneNote Application",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "\\onenote.exe",
          "\\onenotem.exe",
          "\\onenoteim.exe"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\AppData\\Local\\Temp\\OneNote\\",
        "TargetFilename|endswith": [
          ".bat",
          ".chm",
          ".cmd",
          ".dll",
          ".exe",
          ".hta",
          ".htm",
          ".html",
          ".js",
          ".lnk",
          ".ps1",
          ".vbe",
          ".vbs",
          ".wsf"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}