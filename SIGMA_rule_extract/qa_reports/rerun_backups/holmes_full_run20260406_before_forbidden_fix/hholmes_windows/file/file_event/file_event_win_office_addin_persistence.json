{
  "name": "Potential Persistence Via Microsoft Office Add-In",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\Microsoft\\Word\\Startup\\",
          "\\Microsoft\\Excel\\Startup\\",
          "Microsoft\\Excel\\XLSTART\\",
          "\\Microsoft\\Addins\\"
        ],
        "TargetFilename|endswith": [
          ".wll",
          ".xll",
          ".xlam",
          ".xla",
          ".ppam"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}