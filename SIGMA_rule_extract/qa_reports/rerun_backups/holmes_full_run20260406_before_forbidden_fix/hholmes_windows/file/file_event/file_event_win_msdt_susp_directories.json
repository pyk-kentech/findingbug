{
  "name": "File Creation In Suspicious Directory By Msdt.EXE",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\msdt.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\Desktop\\",
          "\\Start Menu\\Programs\\Startup\\",
          "C:\\PerfLogs\\",
          "C:\\ProgramData\\",
          "C:\\Users\\Public\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}