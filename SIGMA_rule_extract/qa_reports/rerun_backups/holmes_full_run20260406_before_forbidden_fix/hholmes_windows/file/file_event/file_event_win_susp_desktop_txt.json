{
  "name": "Suspicious Creation TXT File in User Desktop",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\cmd.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains|all": [
          "\\Users\\",
          "\\Desktop\\"
        ],
        "TargetFilename|endswith": ".txt"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}