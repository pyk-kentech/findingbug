{
  "name": "Potential Webshell Creation On Static Website",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\\\inetpub\\\\wwwroot\\\\",
          ".ashx",
          ".asp",
          ".ph",
          ".soap",
          "\\\\www\\\\",
          "\\\\htdocs\\\\",
          "\\\\html\\\\",
          ".ph"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}