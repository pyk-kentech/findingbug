{
  "name": "PowerShell Profile Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          "\\Microsoft.PowerShell_profile.ps1",
          "\\PowerShell\\profile.ps1",
          "\\Program Files\\PowerShell\\7-preview\\profile.ps1",
          "\\Program Files\\PowerShell\\7\\profile.ps1",
          "\\Windows\\System32\\WindowsPowerShell\\v1.0\\profile.ps1",
          "\\WindowsPowerShell\\profile.ps1"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}