{
  "name": "Potential RipZip Attack on Startup Folder",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\explorer.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains|all": [
          "\\Microsoft\\Windows\\Start Menu\\Programs\\Startup",
          ".lnk.{0AFACED1-E828-11D1-9187-B532F1E9575D}"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}