{
  "name": "Kubernetes Admission Controller Modification",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "verb": [
          "create",
          "delete",
          "patch",
          "replace",
          "update"
        ]
      }
    },
    "object": {
      "type": "Resource",
      "attributes": {
        "objectRef.apiGroup": "admissionregistration.k8s.io",
        "objectRef.resource": [
          "mutatingwebhookconfigurations",
          "validatingwebhookconfigurations"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}