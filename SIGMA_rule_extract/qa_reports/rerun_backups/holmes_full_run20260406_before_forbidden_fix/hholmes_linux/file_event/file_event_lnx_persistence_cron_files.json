{
  "name": "Persistence Via Cron Files",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|startswith": [
          "/etc/cron.d/",
          "/etc/cron.daily/",
          "/etc/cron.hourly/",
          "/etc/cron.monthly/",
          "/etc/cron.weekly/",
          "/var/spool/cron/crontabs/"
        ],
        "TargetFilename|contains": [
          "/etc/cron.allow",
          "/etc/cron.deny",
          "/etc/crontab"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}