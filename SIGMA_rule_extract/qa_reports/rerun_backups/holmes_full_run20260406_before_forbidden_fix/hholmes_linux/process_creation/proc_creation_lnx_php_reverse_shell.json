{
  "name": "Potential PHP Reverse Shell",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|contains": "/php",
        "CommandLine|contains|all": [
          " -r ",
          "fsockopen"
        ],
        "CommandLine|contains": [
          "ash",
          "bash",
          "bsh",
          "csh",
          "ksh",
          "pdksh",
          "sh",
          "tcsh",
          "zsh"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}