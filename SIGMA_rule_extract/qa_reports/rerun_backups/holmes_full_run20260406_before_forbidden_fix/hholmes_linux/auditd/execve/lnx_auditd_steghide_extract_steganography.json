{
  "name": "Steganography Extract Files with Steghide",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Event",
      "attributes": {
        "a0": "steghide",
        "a1": "extract",
        "a2": "-sf"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path|endswith": [
          ".jpg",
          ".png"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}