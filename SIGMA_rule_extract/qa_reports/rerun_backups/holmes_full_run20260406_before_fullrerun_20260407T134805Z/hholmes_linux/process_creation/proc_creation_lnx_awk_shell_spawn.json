{
  "name": "Suspicious Invocation of Shell via AWK - Linux",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/awk",
          "/gawk",
          "/mawk",
          "/nawk"
        ],
        "CommandLine|contains": [
          "BEGIN {system",
          "/bin/bash",
          "/bin/dash",
          "/bin/fish",
          "/bin/sh",
          "/bin/zsh"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}