{
  "name": "Shell Invocation Via Ssh - Linux",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "/ssh",
        "CommandLine|contains": [
          "ProxyCommand=;",
          "permitlocalcommand=yes",
          "localhost"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "/bin/bash",
          "/bin/dash",
          "/bin/fish",
          "/bin/sh",
          "/bin/zsh",
          "sh 0<&2 1>&2",
          "sh 1>&2 0<&2"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}