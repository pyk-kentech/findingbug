{
  "name": "Linux Remote System Discovery",
  "apt_stage": "Internal Recon",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": [
          "/arp",
          "/ping"
        ],
        "CommandLine|contains": [
          "-a",
          " 10.",
          " 192.168.",
          " 172.16.",
          " 172.17.",
          " 172.18.",
          " 172.19.",
          " 172.20.",
          " 172.21.",
          " 172.22.",
          " 172.23.",
          " 172.24.",
          " 172.25.",
          " 172.26.",
          " 172.27.",
          " 172.28.",
          " 172.29.",
          " 172.30.",
          " 172.31.",
          " 127.",
          " 169.254."
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {}
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Establish Foothold",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}