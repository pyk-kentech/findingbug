{
  "name": "Communication To Ngrok Tunneling Service - Linux",
  "apt_stage": "Exfiltration",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "DestinationHostname|contains": [
          "tunnel.us.ngrok.com",
          "tunnel.eu.ngrok.com",
          "tunnel.ap.ngrok.com",
          "tunnel.au.ngrok.com",
          "tunnel.sa.ngrok.com",
          "tunnel.jp.ngrok.com",
          "tunnel.in.ngrok.com"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Collection",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}