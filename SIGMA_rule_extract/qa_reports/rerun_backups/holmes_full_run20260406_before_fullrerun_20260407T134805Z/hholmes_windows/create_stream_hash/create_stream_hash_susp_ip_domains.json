{
  "name": "Unusual File Download from Direct IP Address",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          ".ps1:Zone",
          ".bat:Zone",
          ".exe:Zone",
          ".vbe:Zone",
          ".vbs:Zone",
          ".dll:Zone",
          ".one:Zone",
          ".cmd:Zone",
          ".hta:Zone",
          ".xll:Zone",
          ".lnk:Zone"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}