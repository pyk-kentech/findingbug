{
  "name": "Potentially Suspicious File Download From ZIP TLD",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          ".bat:Zone",
          ".dat:Zone",
          ".dll:Zone",
          ".doc:Zone",
          ".docm:Zone",
          ".exe:Zone",
          ".hta:Zone",
          ".pptm:Zone",
          ".ps1:Zone",
          ".rar:Zone",
          ".rtf:Zone",
          ".sct:Zone",
          ".vbe:Zone",
          ".vbs:Zone",
          ".ws:Zone",
          ".wsf:Zone",
          ".xll:Zone",
          ".xls:Zone",
          ".xlsm:Zone",
          ".zip:Zone"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}