{
  "name": "Meterpreter or Cobalt Strike Getsystem Service Installation - Security",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "*cmd.exe /c echo*",
          "*%COMSPEC% /c echo*",
          "*rundll32*"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "*\\pipe\\*",
          "*.dll,a",
          "\\\\127.0.0.1\\ADMIN$\\*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}