{
  "name": "ETW Logging Disabled In .NET Processes - Registry",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject": [
          "\\SOFTWARE\\Microsoft\\.NETFramework",
          "\\Environment"
        ],
        "Details": [
          "ETWEnabled",
          "COMPlus_ETWEnabled",
          "COMPlus_ETWFlags"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}