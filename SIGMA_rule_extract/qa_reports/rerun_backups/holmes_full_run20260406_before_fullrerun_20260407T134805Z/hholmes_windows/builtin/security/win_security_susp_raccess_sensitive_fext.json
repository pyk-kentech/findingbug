{
  "name": "Suspicious Access to Sensitive File Extensions",
  "apt_stage": "Collection",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "READ",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".bak",
          ".dmp",
          ".edb",
          ".kirbi",
          ".msg",
          ".nsf",
          ".nst",
          ".oab",
          ".ost",
          ".pst",
          ".rdp"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}