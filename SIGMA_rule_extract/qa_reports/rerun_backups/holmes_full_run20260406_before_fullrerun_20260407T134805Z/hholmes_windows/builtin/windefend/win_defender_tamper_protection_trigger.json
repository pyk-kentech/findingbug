{
  "name": "Microsoft Defender Tamper Protection Trigger",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "Registry",
      "attributes": {
        "TargetObject": [
          "\\Windows Defender\\DisableAntiSpyware",
          "\\Windows Defender\\DisableAntiVirus",
          "\\Windows Defender\\Scan\\DisableArchiveScanning",
          "\\Windows Defender\\Scan\\DisableScanningNetworkFiles",
          "\\Real-Time Protection\\DisableRealtimeMonitoring",
          "\\Real-Time Protection\\DisableBehaviorMonitoring",
          "\\Real-Time Protection\\DisableIOAVProtection",
          "\\Real-Time Protection\\DisableScriptScanning"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}