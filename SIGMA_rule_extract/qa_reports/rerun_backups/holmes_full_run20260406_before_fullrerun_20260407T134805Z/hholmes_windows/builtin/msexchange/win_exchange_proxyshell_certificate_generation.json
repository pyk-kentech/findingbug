{
  "name": "Certificate Request Export to Exchange Webserver",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {
        "CommandLine": [
          "New-ExchangeCertificate",
          "-GenerateRequest",
          "-BinaryEncoded",
          "-RequestFile"
        ]
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "\\\\localhost\\C$",
          "\\\\127.0.0.1\\C$",
          "C:\\inetpub",
          "*.aspx"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}