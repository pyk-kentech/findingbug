{
  "name": "MSI Installation From Suspicious Locations",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Provider_Name": "MsiInstaller"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "file_path": [
          "*:\\Windows\\TEMP\\*",
          "*\\\\*",
          "*\\Desktop\\*",
          "*\\PerfLogs\\*",
          "*\\Users\\Public\\*"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}