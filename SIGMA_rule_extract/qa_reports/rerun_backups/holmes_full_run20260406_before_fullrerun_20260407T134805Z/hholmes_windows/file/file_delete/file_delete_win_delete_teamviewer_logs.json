{
  "name": "TeamViewer Log File Deleted",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image": "C:\\Windows\\system32\\svchost.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": "\\TeamViewer_",
        "TargetFilename|endswith": ".log"
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}