{
  "name": "Suspicious File Created by ArcSOC.exe",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "Process",
      "attributes": {
        "Image|endswith": "\\ArcSOC.exe"
      }
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|endswith": [
          ".ahk",
          ".aspx",
          ".au3",
          ".bat",
          ".cmd",
          ".dll",
          ".exe",
          ".hta",
          ".js",
          ".ps1",
          ".py",
          ".vbe",
          ".vbs",
          ".wsf"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}