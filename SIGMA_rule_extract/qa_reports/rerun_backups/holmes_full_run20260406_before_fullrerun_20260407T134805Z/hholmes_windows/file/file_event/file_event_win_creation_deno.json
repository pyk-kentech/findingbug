{
  "name": "Suspicious Deno File Written from Remote Source",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "WRITE",
    "subject": {
      "type": "Process",
      "attributes": {}
    },
    "object": {
      "type": "File",
      "attributes": {
        "TargetFilename|contains": [
          "\\deno\\gen\\",
          "\\deno\\remote\\https\\"
        ],
        "TargetFilename|contains|all": [
          ":\\Users\\",
          "\\AppData\\"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}