{
  "name": "Users Added to Global or Device Admin Roles",
  "apt_stage": "Establish Foothold",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "EXECUTE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "Category": "RoleManagement",
        "OperationName|contains|all": [
          "Add",
          "member to role"
        ]
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "TargetResources|contains": [
          "7698a772-787b-4ac8-901f-60d6b08affd2",
          "62e90394-69f5-4237-9190-012177145e10"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}