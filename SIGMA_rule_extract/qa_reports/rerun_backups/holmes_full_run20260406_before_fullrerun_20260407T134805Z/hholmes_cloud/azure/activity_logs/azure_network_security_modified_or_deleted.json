{
  "name": "Azure Network Security Configuration Modified or Deleted",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CONNECT",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {}
    },
    "object": {
      "type": "NetFlow",
      "attributes": {
        "operationName": [
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/WRITE",
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/DELETE",
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/SECURITYRULES/WRITE",
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/SECURITYRULES/DELETE",
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/JOIN/ACTION",
          "MICROSOFT.NETWORK/NETWORKSECURITYGROUPS/PROVIDERS/MICROSOFT.INSIGHTS/DIAGNOSTICSETTINGS/WRITE"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}