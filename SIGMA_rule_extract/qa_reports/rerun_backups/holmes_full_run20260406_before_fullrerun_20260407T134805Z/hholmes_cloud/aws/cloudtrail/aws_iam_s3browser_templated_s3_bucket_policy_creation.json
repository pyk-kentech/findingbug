{
  "name": "AWS IAM S3Browser Templated S3 Bucket Policy Creation",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventSource": "iam.amazonaws.com",
        "eventName": "PutUserPolicy",
        "userAgent|contains": "S3 Browser"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "requestParameters|contains|all": [
          "\"arn:aws:s3:::<YOUR-BUCKET-NAME>/*\"",
          "\"s3:GetObject\"",
          "\"Allow\""
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "OR",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      },
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Execution",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}