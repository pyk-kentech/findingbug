{
  "name": "Google Workspace Application Removed",
  "apt_stage": "Complete Mission",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "DELETE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {
        "eventService": "admin.googleapis.com"
      }
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "eventName": [
          "REMOVE_APPLICATION",
          "REMOVE_APPLICATION_FROM_WHITELIST"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Lateral Movement",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}