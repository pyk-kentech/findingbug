{
  "name": "Google Cloud Kubernetes RoleBinding",
  "apt_stage": "Execution",
  "severity_score": 5.0,
  "match_logic": {
    "relation": "CREATE",
    "subject": {
      "type": "CloudIdentity",
      "attributes": {}
    },
    "object": {
      "type": "CloudResource",
      "attributes": {
        "TargetFilename": [
          "*clusterrolebindings.create",
          "*rolebindings.create",
          "*clusterrolebindings.patch",
          "*rolebindings.patch",
          "*clusterrolebindings.update",
          "*rolebindings.update",
          "*clusterrolebindings.delete",
          "*rolebindings.delete"
        ]
      }
    },
    "entity_bindings": {
      "subject": "$subject_node",
      "object": "$object_node"
    }
  },
  "prerequisites": {
    "operator": "AND",
    "predicates": [
      {
        "type": "stage_path",
        "quantifier": "EXISTS",
        "source_stage": "Initial Compromise",
        "target_node": "$subject_node",
        "threshold": 1
      }
    ]
  }
}