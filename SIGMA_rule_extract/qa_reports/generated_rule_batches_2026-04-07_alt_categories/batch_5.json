  {
    "source_file": "rules/holmes_full_run20260406/hholmes_windows/create_stream_hash/create_stream_hash_creation_internet_file.json",
    "category": "hholmes_windows/create_stream_hash",
    "rule": {
      "name": "Creation Of a Suspicious ADS File Outside a Browser Download",
      "apt_stage": "Execution",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "CREATE",
        "subject": {
          "type": "Process",
          "attributes": {
            "Contents|startswith": "[ZoneTransfer]  ZoneId=3"
          }
        },
        "object": {
          "type": "File",
          "attributes": {
            "TargetFilename|endswith": ":Zone.Identifier",
            "TargetFilename|contains": [
              ".exe",
              ".scr",
              ".bat",
              ".cmd",
              ".docx",
              ".hta",
              ".jse",
              ".lnk",
              ".pptx",
              ".ps",
              ".reg",
              ".sct",
              ".vb",
              ".wsc",
              ".wsf",
              ".xlsx"
            ]
          }
        },
        "entity_bindings": {
          "subject": "$subject_node",
          "object": "$object_node"
        }
      },
      "prerequisites": {
        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Initial Compromise",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    }
  }
