    "category": "hholmes_windows/create_stream_hash",
    "rule": {
      "name": "Suspicious File Download From File Sharing Websites -  File Stream",
      "apt_stage": "Execution",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "CREATE",
        "subject": {
          "type": "Process",
          "attributes": {}
        },
        "object": {
          "type": "File",
          "attributes": {
            "TargetFilename|contains": [
              ".cpl:Zone",
              ".dll:Zone",
              ".exe:Zone",
              ".hta:Zone",
              ".lnk:Zone",
              ".one:Zone",
              ".vbe:Zone",
              ".vbs:Zone",
              ".xll:Zone"
            ],
            "Contents|contains": [
              ".githubusercontent.com",
              "anonfiles.com",
              "cdn.discordapp.com",
              "ddns.net",
              "dl.dropboxusercontent.com",
              "ghostbin.co",
              "github.com",
              "glitch.me",
              "gofile.io",
              "hastebin.com",
              "mediafire.com",
              "mega.nz",
              "onrender.com",
              "pages.dev",
              "paste.ee",
              "pastebin.com",
              "pastebin.pl",
              "pastetext.net",
              "pixeldrain.com",
              "privatlab.com",
              "privatlab.net",
              "send.exploit.in",
              "sendspace.com",
              "storage.googleapis.com",
              "storjshare.io",
              "supabase.co",
              "temp.sh",
              "transfer.sh",
              "trycloudflare.com",
              "ufile.io",
              "w3spaces.com",
              "workers.dev"
            ]
          }
        },
        "entity_bindings": {
          "subject": "$subject_node",
          "object": "$object_node"
        }
      },
      "prerequisites": {
        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Initial Compromise",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    }
  },
