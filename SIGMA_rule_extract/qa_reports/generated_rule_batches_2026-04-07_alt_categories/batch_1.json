    "category": "hholmes_linux/auditd",
    "rule": {
      "name": "Systemd Service Creation",
      "apt_stage": "Establish Foothold",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "CREATE",
        "subject": {
          "type": "Event",
          "attributes": {}
        },
        "object": {
          "type": "File",
          "attributes": {
            "file_path": [
              "/usr/lib/systemd/system/*",
              "/etc/systemd/system/*",
              "/.config/systemd/user/*"
            ]
          }
        },
        "entity_bindings": {
          "subject": "$subject_node",
          "object": "$object_node"
        }
      },
      "prerequisites": {
        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Execution",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    }
  },
