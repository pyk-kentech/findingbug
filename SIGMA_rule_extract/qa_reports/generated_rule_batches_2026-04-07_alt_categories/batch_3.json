[
  {
    "source_file": "rules/holmes_full_run20260406/hholmes_windows/file/file_access/file_access_win_susp_gpo_files.json",
    "category": "hholmes_windows/file",
    "rule": {
      "name": "Access To Potentially Sensitive Sysvol Files By Uncommon Applications",
      "apt_stage": "Execution",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "READ",
        "subject": {
          "type": "Process",
          "attributes": {
            "Image|startswith": [
              "C:\\Program Files (x86)\\",
              "C:\\Program Files\\",
              "C:\\Windows\\system32\\",
              "C:\\Windows\\SysWOW64\\"
            ],
            "Image": "C:\\Windows\\explorer.exe"
          }
        },
        "object": {
          "type": "File",
          "attributes": {
            "FileName|startswith": "\\\\",
            "FileName|contains|all": [
              "\\sysvol\\",
              "\\Policies\\"
            ],
            "FileName|endswith": [
              "audit.csv",
              "Files.xml",
              "GptTmpl.inf",
              "groups.xml",
              "Registry.pol",
              "Registry.xml",
              "scheduledtasks.xml",
              "scripts.ini",
              "services.xml"
            ]
          }
        },
        "entity_bindings": {
          "subject": "$subject_node",
          "object": "$object_node"
        }
      },
      "prerequisites": {
        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Initial Compromise",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    }
  },
