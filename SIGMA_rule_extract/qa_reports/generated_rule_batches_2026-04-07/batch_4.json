        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Lateral Movement",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    }
