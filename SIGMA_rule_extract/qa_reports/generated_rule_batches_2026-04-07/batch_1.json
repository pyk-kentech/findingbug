    "rule": {
      "name": "Shell Execution GCC  - Linux",
      "apt_stage": "Internal Recon",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "EXECUTE",
        "subject": {
          "type": "Process",
          "attributes": {
            "Image|endswith": [
              "/c89",
              "/c99",
              "/gcc"
            ],
            "CommandLine|contains": "-wrapper"
          }
        },
        "object": {
          "type": "File",
          "attributes": {
            "file_path": [
              "/bin/bash,-s",
              "/bin/dash,-s",
              "/bin/fish,-s",
              "/bin/sh,-s",
              "/bin/zsh,-s"
            ]
          }
