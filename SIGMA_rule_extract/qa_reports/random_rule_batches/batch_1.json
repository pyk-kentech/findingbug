    {
      "name": "VHD Image Download Via Browser",
      "apt_stage": "Execution",
      "severity_score": 5.0,
      "match_logic": {
        "relation": "CREATE",
        "subject": {
          "type": "Process",
          "attributes": {
            "Image|endswith": [
              "\\brave.exe",
              "\\chrome.exe",
              "\\firefox.exe",
              "\\iexplore.exe",
              "\\maxthon.exe",
              "\\MicrosoftEdge.exe",
              "\\msedge.exe",
              "\\msedgewebview2.exe",
              "\\opera.exe",
              "\\safari.exe",
              "\\seamonkey.exe",
              "\\vivaldi.exe",
              "\\whale.exe"
            ]
          }
        },
        "object": {
          "type": "File",
          "attributes": {
            "TargetFilename|contains": ".vhd"
          }
        },
        "entity_bindings": {
          "subject": "$subject_node",
          "object": "$object_node"
        }
      },
      "prerequisites": {
        "operator": "AND",
        "predicates": [
          {
            "type": "stage_path",
            "quantifier": "EXISTS",
            "source_stage": "Initial Compromise",
            "target_node": "$subject_node",
            "threshold": 1
          }
        ]
      }
    },
